OnBootSec=30
OnUnitActiveSec=30
AccuracySec=1

[Install]
WantedBy=timers.target
TMEOF

systemctl daemon-reload
echo "   (Timer systemd 30s instalado pero DESACTIVADO)"
echo "   Para activar: systemctl enable --now watchdog-vpn.timer && crontab -e (borrar línea watchdog)"

# ── Primera corrida ───────────────────────────────────────────────────
echo "   Ejecutando primera corrida del watchdog..."
