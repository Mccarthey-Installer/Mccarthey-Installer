_cd_file()  { echo "${CD_DIR}/$(echo "$1" | tr ':/' '__')"; }
_in_cd() {
    local F; F=$(_cd_file "$1")
    [ -f "$F" ] || return 1
    local LAST NOW
    LAST=$(cat "$F" 2>/dev/null || echo 0)
    NOW=$(date +%s)
    (( NOW - LAST < $2 ))
}
_set_cd() {
    local F; F=$(_cd_file "$1")
    date +%s > "$F"
}
_cd_remaining() {
    local F; F=$(_cd_file "$1")
    [ -f "$F" ] || { echo 0; return; }
    local LAST NOW
    LAST=$(cat "$F" 2>/dev/null || echo 0)
    NOW=$(date +%s)
    echo $(( $2 - (NOW - LAST) ))
}

