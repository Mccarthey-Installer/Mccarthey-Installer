#!/bin/bash
echo "MCCARTHEY VPN FULL - SSL 443 + PROXY 80 + BADVPN + GESTIÓN"
echo "================================================================"
set -e
export TZ="America/El_Salvador"

# === Actualizar sistema ===
echo "Actualizando sistema..."
sudo apt update -y && sudo apt upgrade -y

# === Instalar dependencias necesarias ===
echo "Instalando dependencias..."
sudo apt install -y stunnel4 locales openssl util-linux git cmake build-essential \
curl unzip wget python3 python3-dev python-is-python3 screen net-tools python3-pip cpulimit

# === Configurar idioma y zona horaria ===
echo "Configurando zona horaria e idioma..."
sudo sed -i '/es_SV.UTF-8/s/^# //g' /etc/locale.gen
sudo locale-gen
sudo update-locale LANG=es_SV.UTF-8
sudo timedatectl set-timezone America/El_Salvador

# === Detener servicios previos ===
echo "Deteniendo servicios previos..."
pkill -f stunnel4 || true
pkill -f PDirect.py || true
pkill -f badvpn-udpgw || true
systemctl stop stunnel4 2>/dev/null || true
screen -S badvpn -X quit || true
screen -S badUDP72 -X quit || true

# === Variables principales ===
LOCAL_PORT=22
SSL_PORT=443
SNI_HOST="pruebat.org"
PROXY_PORT=80

# ===========================
# 1. CONFIGURAR STUNNEL: 443 → 22
# ===========================
echo "Generando certificado SSL (CN: $SNI_HOST)..."
mkdir -p /etc/stunnel/certs
openssl req -x509 -newkey rsa:2048 -keyout /etc/stunnel/certs/stunnel.key \
  -out /etc/stunnel/certs/stunnel.crt -days 3650 -nodes -batch \
  -subj "/C=SV/ST=San Salvador/L=Santa Ana/O=McCartheyVPN/OU=SSLService/CN=$SNI_HOST/emailAddress=admin@mccarthey.net"

cat /etc/stunnel/certs/stunnel.key /etc/stunnel/certs/stunnel.crt > /etc/stunnel/certs/stunnel.pem
chmod 600 /etc/stunnel/certs/stunnel.pem

echo "Configurando Stunnel: $SSL_PORT → $LOCAL_PORT"
cat > /etc/stunnel/stunnel.conf <<EOF
pid = /var/run/stunnel4/stunnel.pid
setuid = stunnel4
setgid = stunnel4
debug = 5
output = /var/log/stunnel4/stunnel.log

cert = /etc/stunnel/certs/stunnel.pem
client = no
socket = l:TCP_NODELAY=1
socket = r:TCP_NODELAY=1

[ssh]
accept = $SSL_PORT
connect = 127.0.0.1:$LOCAL_PORT
EOF

sed -i 's/ENABLED=0/ENABLED=1/' /etc/default/stunnel4
systemctl enable stunnel4
systemctl restart stunnel4

# ===========================
# 2. PROXY PYTHON EN PUERTO 80 (DIRECTORIO MCCARTHEY)
# ===========================
echo "Configurando Proxy Python en puerto $PROXY_PORT..."
mkdir -p /etc/MCCARTHEY

cat > /etc/MCCARTHEY/PDirect.py << 'EOF'
#!/usr/bin/env python3
# encoding: utf-8

import asyncio
import sys
import socket
import time

LISTENING_ADDR = '0.0.0.0'
LISTENING_PORT = int(sys.argv[1]) if len(sys.argv) > 1 else 80
PASS = ''
BUFLEN = 4096 * 4
TIMEOUT = 60
DEFAULT_HOST = '127.0.0.1:22'
STATUS_RESP = '101'
FTAG = '\r\nContent-length: 0\r\n\r\nHTTP/1.1 200 Connection Established\r\n\r\n'
STATUS_TXT = '<strong style="color: #ff0000;">Kang Sae-byeok</strong>'
RESPONSE = f"HTTP/1.1 {STATUS_RESP} {STATUS_TXT} {FTAG}"

MAX_CONNECTIONS = 50
semaphore = asyncio.Semaphore(MAX_CONNECTIONS)

def find_header(header, data):
    try:
        data_str = data.decode(errors='ignore')
        start = data_str.find(header + ": ")
        if start == -1:
            return ""
        start += len(header) + 2
        end = data_str.find("\r\n", start)
        return data_str[start:end] if end != -1 else data_str[start:]
    except Exception:
        return ""

async def connect_target(host_port):
    try:
        if ':' in host_port:
            host, port = host_port.split(':')
            port = int(port)
        else:
            host = host_port
            port = 22
        reader, writer = await asyncio.open_connection(host, port)
        return reader, writer
    except Exception as e:
        return None, None

async def handle_client(client_reader, client_writer):
    async with semaphore:
        client_addr = client_writer.get_extra_info('peername')
        log_prefix = f"Connection: {client_addr}"
        try:
            data = await asyncio.wait_for(client_reader.read(BUFLEN), timeout=TIMEOUT)
            if not data:
                client_writer.close()
                await client_writer.wait_closed()
                return

            host_port = find_header('X-Real-Host', data) or DEFAULT_HOST
            split = find_header('X-Split', data)
            passwd = find_header('X-Pass', data)

            if split:
                await client_reader.read(BUFLEN)

            if PASS and passwd != PASS:
                client_writer.write(b'HTTP/1.1 400 WrongPass!\r\n\r\n')
                await client_writer.drain()
                client_writer.close()
                await client_writer.wait_closed()
                return
            elif host_port.startswith('127.0.0.1') or host_port.startswith('localhost') or not PASS:
                target_reader, target_writer = await connect_target(host_port)
                if not target_reader:
                    client_writer.close()
                    await client_writer.wait_closed()
                    return
                client_writer.write(RESPONSE.encode())
                await client_writer.drain()

                await asyncio.gather(
                    proxy_data(client_reader, target_writer),
                    proxy_data(target_reader, client_writer)
                )
        except Exception as e:
            print(f"{log_prefix} - error: {e}")
        finally:
            client_writer.close()
            await client_writer.wait_closed()

async def proxy_data(reader, writer):
    try:
        while True:
            data = await reader.read(BUFLEN)
            if not data:
                break
            writer.write(data)
            await writer.drain()
    except Exception:
        pass
    finally:
        try:
            writer.close()
            await writer.wait_closed()
        except Exception:
            pass

async def main(host=LISTENING_ADDR, port=LISTENING_PORT):
    server = await asyncio.start_server(handle_client, host, port)
    addrs = ', '.join(str(sock.getsockname()) for sock in server.sockets)
    print("PROXY HTTP MCCARTHEY - VPS TUNNEL")
    print("IP:", host)
    print("PORTA:", port)
    print("Powered by MCC-KEY System")
    print(f"Listening on: {addrs}")
    async with server:
        await server.serve_forever()

if __name__ == '__main__':
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        print("Parando servidor...")
EOF

chmod +x /etc/MCCARTHEY/PDirect.py
nohup python3 /etc/MCCARTHEY/PDirect.py $PROXY_PORT > /root/nohup.out 2>&1 &

# ===========================
# 3. BADVPN EN 7200 Y 7300
# ===========================
echo "Compilando BadVPN (7200 y 7300)..."
rm -rf /opt/badvpn
git clone https://github.com/ambrop72/badvpn.git /opt/badvpn
mkdir -p /opt/badvpn/build && cd /opt/badvpn/build
cmake .. -DBUILD_NOTHING_BY_DEFAULT=1 -DBUILD_UDPGW=1
make -j$(nproc)
cp udpgw/badvpn-udpgw /usr/bin/
chmod +x /usr/bin/badvpn-udpgw

screen -dmS badvpn /usr/bin/badvpn-udpgw --listen-addr 127.0.0.1:7300 --max-clients 1000 --max-connections-for-client 10
screen -dmS badUDP72 /usr/bin/badvpn-udpgw --listen-addr 127.0.0.1:7200 --max-clients 1000 --max-connections-for-client 10

# ===========================
# 4. AUTOARRANQUE CON rc.local
# ===========================
echo "Configurando autoarranque..."
cat > /etc/rc.local <<EOF
#!/bin/bash
sleep 15
nohup python3 /etc/MCCARTHEY/PDirect.py $PROXY_PORT > /root/nohup.out 2>&1 &
screen -dmS badvpn /usr/bin/badvpn-udpgw --listen-addr 127.0.0.1:7300 --max-clients 1000 --max-connections-for-client 10
screen -dmS badUDP72 /usr/bin/badvpn-udpgw --listen-addr 127.0.0.1:7200 --max-clients 1000 --max-connections-for-client 10
systemctl restart stunnel4
exit 0
EOF
chmod +x /etc/rc.local

cat > /etc/systemd/system/rc-local.service <<EOF
[Unit]
Description=/etc/rc.local Compatibility
ConditionPathExists=/etc/rc.local

[Service]
Type=forking
ExecStart=/etc/rc.local start
TimeoutSec=0
StandardOutput=tty
RemainAfterExit=yes
SysVStartPriority=99

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable rc-local
systemctl start rc-local

# ===========================
# 5. GESTIÓN DE RECURSOS (RAM + CPU)
# ===========================
echo "Configurando gestión automática de RAM y CPU..."
touch /var/log/gestionar_recursos.log
chmod 644 /var/log/gestionar_recursos.log

cat > /root/gestionar_recursos.sh << 'EOF'
#!/bin/bash
LOCK_FILE="/tmp/gestionar_recursos.lock"
LOG_FILE="/var/log/gestionar_recursos.log"
PID_FILE="/tmp/cpulimit_pids.txt"

if [ -f "$LOCK_FILE" ]; then
    echo "$(date): Proceso ya en ejecución." >> "$LOG_FILE"
    exit 1
fi

touch "$LOCK_FILE"
trap 'rm -f "$LOCK_FILE"; exit' INT TERM EXIT

cleanup_cpulimit() {
    if [ -f "$PID_FILE" ]; then
        while read -r cpid; do
            kill -9 "$cpid" 2>/dev/null || true
        done < "$PID_FILE"
        > "$PID_FILE"
    fi
    pkill -9 -f "cpulimit -p" 2>/dev/null
}

cleanup_cpulimit

if ! pgrep -f "/root/scrip.sh mon" > /dev/null; then
    /bin/bash /root/scrip.sh mon &
    echo "$(date): Iniciado scrip.sh mon" >> "$LOG_FILE"
fi

MEM_THRESHOLD=200
CACHE_THRESHOLD=100
LOAD_THRESHOLD=2.0
PREV_PIDS_PDIRECT=""
PREV_PIDS_BADVPN=""
PREV_PIDS_SCRIP=""

while true; do
    FREE_MEM=$(free -m | awk '/Mem:/ {print $4}')
    CACHE_MEM=$(free -m | awk '/Mem:/ {print $6}')

    if [ "$FREE_MEM" -lt "$MEM_THRESHOLD" ] || [ "$CACHE_MEM" -gt "$CACHE_THRESHOLD" ]; then
        echo "$(date): Liberando caché (Libre: $FREE_MEM MB, Caché: $CACHE_MEM MB)" >> "$LOG_FILE"
        sync && sudo sysctl -w vm.drop_caches=3 > /dev/null
    fi

    LOAD_AVG=$(awk '{print $1}' /proc/loadavg)
    if (( $(echo "$LOAD_AVG > $LOAD_THRESHOLD" | bc -l) )); then
        CURRENT_PIDS_PDIRECT=$(pgrep -f /etc/MCCARTHEY/PDirect.py)
        CURRENT_PIDS_BADVPN=$(pgrep -f badvpn-udpgw)
        CURRENT_PIDS_SCRIP=$(pgrep -f "/root/scrip.sh mon")

        if [ "$CURRENT_PIDS_PDIRECT" != "$PREV_PIDS_PDIRECT" ] || [ "$CURRENT_PIDS_BADVPN" != "$PREV_PIDS_BADVPN" ] || [ "$CURRENT_PIDS_SCRIP" != "$PREV_PIDS_SCRIP" ]; then
            cleanup_cpulimit

            for pid in $CURRENT_PIDS_PDIRECT; do
                cpulimit -p "$pid" -l 20 -b &
                echo $! >> "$PID_FILE"
            done

            for pid in $CURRENT_PIDS_BADVPN; do
                cpulimit -p "$pid" -l 60 -b &
                echo $! >> "$PID_FILE"
            done

            for pid in $CURRENT_PIDS_SCRIP; do
                cpulimit -p "$pid" -l 10 -b &
                echo $! >> "$PID_FILE"
            done

            PREV_PIDS_PDIRECT="$CURRENT_PIDS_PDIRECT"
            PREV_PIDS_BADVPN="$CURRENT_PIDS_BADVPN"
            PREV_PIDS_SCRIP="$CURRENT_PIDS_SCRIP"
        fi
    fi

    sleep 10
done
EOF

chmod +x /root/gestionar_recursos.sh

cat > /etc/systemd/system/gestionar-recursos.service <<EOF
[Unit]
Description=Gestión de RAM y CPU
After=network.target rc-local.service stunnel4.service

[Service]
Type=simple
User=root
ExecStart=/bin/bash /root/gestionar_recursos.sh
ExecStop=/bin/bash -c "pkill -9 -f 'cpulimit -p'; rm -f /tmp/cpulimit_pids.txt"
Restart=always
RestartSec=5s

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
systemctl enable gestionar-recursos.service
systemctl start gestionar-recursos.service

# ===========================
# 6. CLEAN-VPS — Limpieza automática diaria
# ===========================
echo "Instalando clean-vps (limpieza automática)..."

cat > /usr/local/sbin/clean-vps.sh << 'CLEANEOF'
#!/bin/bash
# =============================================================================
# clean-vps.sh — Limpieza directa para VPS personal
# v2.1 — Sin backups, sin historia, el camión se lleva todo 🚛
# =============================================================================

LOG="/var/log/clean-vps.log"
LOCK="/tmp/clean-vps.lock"
DRY_RUN=false
ERRORS=0

for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=true ;;
    --help)
      echo "Uso: $0 [--dry-run]"
      echo "  --dry-run   Muestra qué haría sin ejecutar nada"
      exit 0
      ;;
  esac
done

log() {
  echo "[$(date +%Y-%m-%d %H:%M:%S)] $1" | tee -a "$LOG"
}

run() {
  if $DRY_RUN; then
    log "[DRY-RUN] $*"
  else
    eval "$@" >> "$LOG" 2>&1 || {
      log "⚠️  Falló: $*"
      ((ERRORS++))
    }
  fi
}

if [[ $EUID -ne 0 ]]; then
  echo "❌ Ejecutá como root: sudo $0"
  exit 1
fi

exec 9>"$LOCK"
flock -n 9 || {
  log "⚠️  Ya hay una instancia corriendo. Abortando."
  exit 1
}

echo "" >> "$LOG"
echo "=== $(date) ===" >> "$LOG"
$DRY_RUN && log "👁️  Modo DRY-RUN activo"
log "🚀 Iniciando limpieza..."

ESPACIO_ANTES=$(df / | awk 'NR==2{print $3}')

log "🧹 APT autoremove + clean..."
run "apt-get autoremove -y"
run "apt-get clean"

log "🧠 Eliminando kernels viejos..."
CURRENT=$(uname -r)
OLD_KERNELS=$(dpkg -l 'linux-image-*' | awk '/^ii/{print $2}' | \
  grep -v "$CURRENT" | sort -V | head -n -2)
if [[ -n "$OLD_KERNELS" ]]; then
  run "echo '$OLD_KERNELS' | xargs --no-run-if-empty apt-get purge -y"
else
  log "✔️  Sin kernels viejos"
fi

log "📊 Journald → 100MB..."
run "journalctl --rotate"
run "journalctl --vacuum-size=100M"

log "🗑️  Borrando logs rotados (+7 días)..."
if $DRY_RUN; then
  find /var/log -maxdepth 1 -type f \( -name "*.gz" -o -name "*.old" -o -name "*.[0-9]" \) \
    -mtime +7 | while read f; do log "[DRY-RUN] Borraría: $f"; done
else
  find /var/log -maxdepth 1 -type f \( -name "*.gz" -o -name "*.old" -o -name "*.[0-9]" \) \
    -mtime +7 -delete >> "$LOG" 2>&1
fi

log "💣 Truncando logs grandes (+50MB)..."
find /var/log -type f -size +50M | while read f; do
  [[ "$f" == "$LOG" ]] && continue
  SIZE_MB=$(du -m "$f" 2>/dev/null | cut -f1)
  if $DRY_RUN; then
    log "[DRY-RUN] Truncaría: $f (${SIZE_MB}MB)"
  else
    truncate -s 0 "$f"
    log "💣 Truncado: $f (${SIZE_MB}MB)"
  fi
done

log "🧹 Cache root (+30 días)..."
if $DRY_RUN; then
  find /root/.cache -type f -mtime +30 | wc -l | \
    xargs -I{} log "[DRY-RUN] {} archivos a eliminar en /root/.cache"
else
  find /root/.cache -type f -mtime +30 -delete 2>/dev/null
fi

log "🧹 /tmp (+7 días)..."
if $DRY_RUN; then
  find /tmp -type f -mtime +7 | wc -l | \
    xargs -I{} log "[DRY-RUN] {} archivos a eliminar en /tmp"
else
  find /tmp -type f -mtime +7 -delete 2>/dev/null
fi

if command -v snap &>/dev/null; then
  log "📦 Limpiando snaps viejos..."
  snap list --all 2>/dev/null | awk '/disabled/{print $1, $3}' | \
  while read snapname revision; do
    if $DRY_RUN; then
      log "[DRY-RUN] Removería snap: $snapname rev.$revision"
    else
      run "snap remove '$snapname' --revision='$revision'"
    fi
  done
else
  log "⏭️  Snap no instalado, saltando..."
fi

if ! $DRY_RUN; then
  cat > /etc/logrotate.d/clean-vps <<LREOF
/var/log/clean-vps.log {
  weekly
  rotate 4
  compress
  missingok
  notifempty
}
LREOF
  log "📄 Logrotate OK"
fi

ESPACIO_DESPUES=$(df / | awk 'NR==2{print $3}')
LIBERADO_MB=$(( (ESPACIO_ANTES - ESPACIO_DESPUES) / 1024 ))
LIBRE=$(df -h / | awk 'NR==2{print $4}')

echo "" >> "$LOG"
log "─────────────────────────────────────────"
if $DRY_RUN; then
  log "👁️  DRY-RUN finalizado — no se tocó nada"
else
  log "📉 Liberado: ${LIBERADO_MB}MB  |  Libre en /: $LIBRE"
  [[ $ERRORS -gt 0 ]] \
    && log "⚠️  $ERRORS error(es) — revisá: $LOG" \
    || log "✅ Limpieza sin errores"
fi
log "─────────────────────────────────────────"
echo "" >> "$LOG"
CLEANEOF

chmod +x /usr/local/sbin/clean-vps.sh

# Registrar cron 0 3 * * *
# FIX: || true para que set -e no mate el script si no existe crontab aún
CRON_JOB="0 3 * * * /usr/local/sbin/clean-vps.sh"
CRON_TMP=$(mktemp)
crontab -l 2>/dev/null > "$CRON_TMP" || true
if ! grep -qF "clean-vps.sh" "$CRON_TMP"; then
  echo "$CRON_JOB" >> "$CRON_TMP"
  crontab "$CRON_TMP" && echo "⏰ Cron clean-vps registrado: $CRON_JOB"
fi
rm -f "$CRON_TMP"

echo "✅ clean-vps instalado y cron activo (3am diario)"

# ===========================
# 7. MENSAJE FINAL
# ===========================
sleep 2
echo ""
echo "========================================"
echo "MCCARTHEY VPN FULL - INSTALACIÓN COMPLETA"
echo "========================================"
echo "SSL: $SSL_PORT → $LOCAL_PORT (Stunnel)"
echo "   Certificado CN: $SNI_HOST"
echo "   Cliente: Host=TU_IP, Puerto=443, SNI=$SNI_HOST"
echo ""
echo "Proxy HTTP: $PROXY_PORT → 22 (HTTP Custom/Injector)"
echo "   Payload: [VACÍO]"
echo ""
echo "BadVPN UDP: 7200 y 7300"
echo ""
echo "Gestión de RAM/CPU activa"
echo ""
echo "Limpieza automática: diaria a las 3am"
echo "   Script : /usr/local/sbin/clean-vps.sh"
echo "   Log    : /var/log/clean-vps.log"
echo "   Manual : clean-vps.sh [--dry-run]"
echo ""
echo "Verificar:"
echo "   ss -tulnp | grep -E ':443|:80|:7200|:7300'"
echo "   systemctl status stunnel4"
echo "   systemctl status gestionar-recursos"
echo "   crontab -l"
echo ""
echo "Reinicio automático configurado"
echo "========================================"
echo ""

exit 0
