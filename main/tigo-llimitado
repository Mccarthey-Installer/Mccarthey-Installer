echo "*/5 * * * * /root/mcc_semaforo.sh" >> "$CRON_TMP_SEM"
crontab "$CRON_TMP_SEM"
rm -f "$CRON_TMP_SEM"

# ── Primera corrida para verificar ───────────────────────────────────
echo "   Ejecutando primera corrida del semáforo v2..."
bash /root/mcc_semaforo.sh

CRON_OK=false; LOG_OK=false
crontab -l 2>/dev/null | grep -q "mcc_semaforo.sh" && CRON_OK=true
[ -f /var/log/mcc_semaforo.log ] && LOG_OK=true

if $CRON_OK && $LOG_OK; then
    echo "✅ Semáforo v2 activo (cron cada 5 min)"
else
    $CRON_OK || echo "❌ cron no quedó registrado — verificá: crontab -l"
    $LOG_OK  || echo "❌ log no existe en /var/log/mcc_semaforo.log"
fi

# ===========================
# 6. CLEAN-VPS — Limpieza automática diaria
# ===========================
echo "Instalando clean-vps (limpieza automática)..."

cat > /usr/local/sbin/clean-vps.sh << 'CLEANEOF'
#!/bin/bash

# ===========================
# 6. CLEAN-VPS — Limpieza automática diaria
# ===========================
