# ══════════════════════════════════════════════════════════════════════
# [E] SELF_PIDS — Construcción del conjunto de PIDs propios
# ══════════════════════════════════════════════════════════════════════
declare -A SELF_PIDS

_build_self_pids() {
    SELF_PIDS[$$]=1
    SELF_PIDS[$PPID]=1

    local WALK_PID=$PPID
    local MAX_DEPTH=10
    local DEPTH=0

    while [ "$WALK_PID" -gt 1 ] 2>/dev/null && [ "$DEPTH" -lt "$MAX_DEPTH" ]; do
        [ -f "/proc/$WALK_PID/status" ] || break
        local PARENT
        PARENT=$(awk '/^PPid:/{print $2}' "/proc/$WALK_PID/status" 2>/dev/null)
        PARENT=${PARENT:-0}
        [ "$PARENT" -le 1 ] && break
        SELF_PIDS[$PARENT]=1
        WALK_PID=$PARENT
        (( DEPTH++ ))
    done

    log "SELF-EXCL: PIDs propios excluidos del scan: ${!SELF_PIDS[*]}"
}

# ══════════════════════════════════════════════════════════════════════
# [F] is_self_pid() — Lookup O(1) en el conjunto SELF_PIDS
# ══════════════════════════════════════════════════════════════════════
is_self_pid() {
    [ -n "${SELF_PIDS[$1]}" ]
}

_build_self_pids

# ══════════════════════════════════════════════════════════════════════
# [A] safe_int()
# ══════════════════════════════════════════════════════════════════════
safe_int() {
    local RAW="${1:-0}"
    RAW="${RAW// /}"
    [[ "$RAW" =~ ^-?[0-9]+$ ]] || { echo 0; return; }
    [ "$RAW" -lt 0 ] 2>/dev/null && { echo 0; return; }
    echo "$RAW"
}

# ══════════════════════════════════════════════════════════════════════
# [B] safe_pct()
# ══════════════════════════════════════════════════════════════════════
safe_pct() {
    local NUM; NUM=$(safe_int "${1:-0}")
    local DEN; DEN=$(safe_int "${2:-0}")
    [ "$DEN" -le 0 ] && { echo 0; return; }
    awk "BEGIN {printf \"%.0f\", ($NUM / $DEN) * 100}"
}

# ══════════════════════════════════════════════════════════════════════
# [C] safe_pid_ticks()
# ══════════════════════════════════════════════════════════════════════
safe_pid_ticks() {
    local PID="$1"
    [ -d "/proc/$PID" ]      || { echo 0; return; }
    [ -f "/proc/$PID/stat" ] || { echo 0; return; }

    local STAT_LINE
    STAT_LINE=$(cat "/proc/$PID/stat" 2>/dev/null) || { echo 0; return; }

    local FC
    FC=$(echo "$STAT_LINE" | awk '{print NF}')
    [ "$(safe_int "$FC")" -lt 17 ] && { echo 0; return; }

    local TICKS
    TICKS=$(echo "$STAT_LINE" | awk '{t=$14+$15+$16+$17; print (t==int(t) && t>=0) ? int(t) : 0}' 2>/dev/null)
    safe_int "$TICKS"
}

# ══════════════════════════════════════════════════════════════════════
# [D] safe_vmrss()
# ══════════════════════════════════════════════════════════════════════
safe_vmrss() {
    local PID="$1"
    [ -d "/proc/$PID" ]        || { echo 0; return; }
    [ -f "/proc/$PID/status" ] || { echo 0; return; }

    local RAW
    RAW=$(awk '/^VmRSS:/{print $2}' "/proc/$PID/status" 2>/dev/null)
    safe_int "$RAW"
}

# ══════════════════════════════════════════════════════════════════════
# Helpers cooldown
# ══════════════════════════════════════════════════════════════════════
_cd_file()  { echo "${CD_DIR}/$(echo "$1" | tr ':/' '__')"; }
_in_cd() {
    local F; F=$(_cd_file "$1")
    [ -f "$F" ] || return 1
    local LAST NOW
    LAST=$(safe_int "$(cat "$F" 2>/dev/null)")
    NOW=$(date +%s)
    (( NOW - LAST < $2 ))
}
_set_cd() {
    local F; F=$(_cd_file "$1")
    date +%s > "$F"
}
_cd_remaining() {
    local F; F=$(_cd_file "$1")
    [ -f "$F" ] || { echo 0; return; }
    local LAST NOW
    LAST=$(safe_int "$(cat "$F" 2>/dev/null)")
    NOW=$(date +%s)
    echo $(( $2 - (NOW - LAST) ))
}

# ══════════════════════════════════════════════════════════════════════
# Lectura CPU sistema
# ══════════════════════════════════════════════════════════════════════
read_sys_stat() {
    awk '/^cpu / {
        idle=$5+$6; total=0
        for(i=2;i<=NF;i++) total+=$i
        print int(total), int(idle); exit
    }' /proc/stat 2>/dev/null
}

# ══════════════════════════════════════════════════════════════════════
# read_cpu_now() — snapshot rápido de CPU actual (sin prescan completo)
# Usado para verificar CPU post-acción sin consumir tiempo de un scan
# completo. Mide durante SAMPLE_INTERVAL segundos.
# ══════════════════════════════════════════════════════════════════════
read_cpu_now() {
    local S0; S0=$(read_sys_stat)
    [ -z "$S0" ] && { echo 0; return; }
    sleep "$SAMPLE_INTERVAL"
    local S1; S1=$(read_sys_stat)
    [ -z "$S1" ] && { echo 0; return; }

    local T0 I0 T1 I1
    T0=$(safe_int "$(echo "$S0" | awk '{print $1}')")
    I0=$(safe_int "$(echo "$S0" | awk '{print $2}')")
    T1=$(safe_int "$(echo "$S1" | awk '{print $1}')")
    I1=$(safe_int "$(echo "$S1" | awk '{print $2}')")

    local DTOTAL=$(( T1 - T0 ))
    [ "$DTOTAL" -le 0 ] && { echo 0; return; }
    local DBUSY=$(( (T1 - T0) - (I1 - I0) ))
    [ "$DBUSY" -lt 0 ] && DBUSY=0
    safe_pct "$DBUSY" "$DTOTAL"
}

# ══════════════════════════════════════════════════════════════════════
# [J] do_unknown_level1() — Reinicio preventivo de servicios propios
#
# Lógica:
#   No sabemos quién está causando la carga, pero sí controlamos
#   nuestros propios servicios. Reiniciarlos libera conexiones
#   colgadas, descriptores acumulados y memoria de heap que los
#   servicios pueden retener con el tiempo.
#
#   Solo reinicia servicios que están corriendo actualmente.
#   No resucita servicios que estaban caídos antes del problema.
#
#   Después de reiniciar, mide CPU nuevamente para saber si ayudó.
#   Si CPU bajó: loguea éxito y resetea contador unknown.
#   Si CPU sigue alta: loguea que level2 puede ser necesario.
# ══════════════════════════════════════════════════════════════════════
do_unknown_level1() {
    local CURRENT_CPU="$1"

    log "UNKNOWN-L1: CPU=${CURRENT_CPU}% sin culprit identificable — iniciando reinicio preventivo de servicios"

    local RESTARTED=0

    # xray — solo si está corriendo
    if pgrep -x xray > /dev/null 2>&1; then
        log "UNKNOWN-L1: reiniciando xray..."
        x-ui restart-xray >> "$LOG" 2>&1 \
            && { log "UNKNOWN-L1: xray reiniciado OK"; (( RESTARTED++ )); } \
            || log "UNKNOWN-L1: xray reinicio falló (no crítico)"
        sleep 1
    else
        log "UNKNOWN-L1: xray no está corriendo — saltando"
    fi

    # proxy — solo si está corriendo
    if pgrep -f "$PROXY_SCRIPT" > /dev/null 2>&1; then
        log "UNKNOWN-L1: reiniciando proxy (PDirect.py)..."
        pkill -f "$PROXY_SCRIPT" 2>/dev/null
        sleep 2
        nohup python3 "$PROXY_SCRIPT" "$PROXY_PORT" > /root/nohup.out 2>&1 &
        sleep 1
        pgrep -f "$PROXY_SCRIPT" > /dev/null 2>&1 \
            && { log "UNKNOWN-L1: proxy reiniciado OK (PID $(pgrep -f "$PROXY_SCRIPT" | head -1))"; (( RESTARTED++ )); } \
            || log "UNKNOWN-L1: proxy reinicio falló — no arrancó"
    else
        log "UNKNOWN-L1: proxy no está corriendo — saltando"
    fi

    # badvpn — solo si está corriendo
    if pgrep -x badvpn-udpgw > /dev/null 2>&1; then
        log "UNKNOWN-L1: reiniciando badvpn..."
        pkill -f "badvpn-udpgw" 2>/dev/null
        screen -S badvpn   -X quit 2>/dev/null
        screen -S badUDP72 -X quit 2>/dev/null
        sleep 2
        screen -dmS badvpn   /usr/bin/badvpn-udpgw --listen-addr 127.0.0.1:7300 \
            --max-clients 1000 --max-connections-for-client 10
        screen -dmS badUDP72 /usr/bin/badvpn-udpgw --listen-addr 127.0.0.1:7200 \
            --max-clients 1000 --max-connections-for-client 10
        sleep 1
        pgrep -x badvpn-udpgw > /dev/null 2>&1 \
            && { log "UNKNOWN-L1: badvpn reiniciado OK"; (( RESTARTED++ )); } \
            || log "UNKNOWN-L1: badvpn reinicio falló"
    else
        log "UNKNOWN-L1: badvpn no está corriendo — saltando"
    fi

    # stunnel — solo si está activo
    if systemctl is-active stunnel4 > /dev/null 2>&1; then
        log "UNKNOWN-L1: reiniciando stunnel4..."
        systemctl restart stunnel4 >> "$LOG" 2>&1 \
            && { log "UNKNOWN-L1: stunnel4 reiniciado OK"; (( RESTARTED++ )); } \
            || log "UNKNOWN-L1: stunnel4 reinicio falló"
    else
        log "UNKNOWN-L1: stunnel4 no está activo — saltando"
    fi

    log "UNKNOWN-L1: ${RESTARTED} servicios reiniciados — midiendo CPU post-acción..."

    # Verificar CPU post-reinicio
    local CPU_POST; CPU_POST=$(read_cpu_now)
    log "UNKNOWN-L1: CPU post-reinicio = ${CPU_POST}%"

    if [ "$CPU_POST" -lt "$CPU_WARN" ]; then
        log "UNKNOWN-L1: ✅ CPU normalizada (${CPU_POST}%) — reinicio preventivo efectivo"
        echo "0" > "$UNKNOWN_CTR_FILE"
    elif [ "$CPU_POST" -lt "$CPU_CRIT" ]; then
        log "UNKNOWN-L1: CPU bajó a ${CPU_POST}% (bajo crítico) — monitoreando"
    else
        log "UNKNOWN-L1: ⚠️  CPU sigue en ${CPU_POST}% (>=${CPU_CRIT}%) — level2 puede ser necesario en próximo ciclo"
    fi

    _set_cd "unknown_l1"
}

# ══════════════════════════════════════════════════════════════════════
# [K] do_unknown_level2() — Liberación de cache del kernel
#
# Lógica:
#   drop_caches libera: page cache (1), dentries+inodes (2), ambos (3).
#   Usamos valor 3 para máxima liberación.
#   SIEMPRE se hace sync previo para no perder escrituras pendientes.
#   No afecta datos de aplicaciones en memoria: solo cache del kernel.
#
#   En VPS con muchas conexiones SSH/tunnel, el kernel puede retener
#   page cache de archivos ya cerrados, ocupando RAM que el sistema
#   interpreta como "usada" aunque sea recuperable.
#
#   Cuándo aplica:
#     - Level1 ya se ejecutó en este ciclo o en el anterior
#     - CPU sigue >= CPU_CRIT después del level1
#     - Cooldown de level2 no está activo
# ══════════════════════════════════════════════════════════════════════
do_unknown_level2() {
    local CURRENT_CPU="$1"

    log "UNKNOWN-L2: CPU=${CURRENT_CPU}% persiste — liberando cache del kernel"

    local RAM_ANTES; RAM_ANTES=$(free -m | awk '/^Mem:/{print $4}')
    log "UNKNOWN-L2: RAM libre antes = ${RAM_ANTES}MB"

    # sync primero — no perder escrituras pendientes
    sync
    log "UNKNOWN-L2: sync completado"

    # drop_caches: 3 = page cache + dentries + inodes
    echo 3 > /proc/sys/vm/drop_caches 2>/dev/null \
        && log "UNKNOWN-L2: drop_caches=3 ejecutado OK" \
        || log "UNKNOWN-L2: drop_caches falló (¿permisos?)"

    sleep 1

    local RAM_DESPUES; RAM_DESPUES=$(free -m | awk '/^Mem:/{print $4}')
    local RAM_LIBERADA=$(( RAM_DESPUES - RAM_ANTES ))
    log "UNKNOWN-L2: RAM libre después = ${RAM_DESPUES}MB (liberados: ${RAM_LIBERADA}MB)"

    local CPU_POST; CPU_POST=$(read_cpu_now)
    log "UNKNOWN-L2: CPU post-drop_caches = ${CPU_POST}%"

    if [ "$CPU_POST" -lt "$CPU_WARN" ]; then
        log "UNKNOWN-L2: ✅ CPU normalizada (${CPU_POST}%) — drop_caches efectivo"
        echo "0" > "$UNKNOWN_CTR_FILE"
    else
        log "UNKNOWN-L2: CPU en ${CPU_POST}% — carga no es por cache de memoria"
        log "UNKNOWN-L2: revisar manualmente: top, iostat, vmstat"
    fi

    _set_cd "unknown_l2"
}

# ══════════════════════════════════════════════════════════════════════
# Prescan T0
# ══════════════════════════════════════════════════════════════════════
declare -A ALL_TICKS_T0
declare -A ALL_COMM

prescan_t0() {
    ALL_TICKS_T0=()
    ALL_COMM=()
    for STATF in /proc/[0-9]*/stat; do
        local PID="${STATF%/stat}"; PID="${PID##*/}"
        [ "$PID" = "1" ] && continue
        [ -d "/proc/$PID" ] || continue
        is_self_pid "$PID" && continue   # [F]
        local COMM
        COMM=$(cat "/proc/$PID/comm" 2>/dev/null || echo "")
        [ -z "$COMM" ] && continue
        echo "$COMM" | grep -qE "$SAFE_PROCS_RE" && continue
        ALL_TICKS_T0[$PID]=$(safe_pid_ticks "$PID")
        ALL_COMM[$PID]="$COMM"
    done
}

# ══════════════════════════════════════════════════════════════════════
# identify_culprit()
# ══════════════════════════════════════════════════════════════════════
identify_culprit() {
    CULPRIT="unknown"
    CULPRIT_CPU=0
    CULPRIT_MEM=0
    CULPRIT_GROUP_PIDS=""
    EXTRA_CULPRITS=""
    SYS_CPU_PCT=0

    local SYS_T0
    SYS_T0=$(read_sys_stat)
    if [ -z "$SYS_T0" ]; then
        log "ERROR: no se pudo leer /proc/stat — abortando ciclo"
        return
    fi
    local SYS_TOTAL_T0 SYS_IDLE_T0
    SYS_TOTAL_T0=$(safe_int "$(echo "$SYS_T0" | awk '{print $1}')")
    SYS_IDLE_T0=$(safe_int  "$(echo "$SYS_T0" | awk '{print $2}')")

    declare -A PID_TAG
    declare -A TAG_MEM_KB

    _add_known() {
        local TAG="$1"; shift
        for PID in "$@"; do
            [ -d "/proc/$PID" ] || continue
            is_self_pid "$PID" && { log "SELF-EXCL: PID $PID ($TAG) es PID propio — ignorado en known"; continue; }
            PID_TAG[$PID]="$TAG"
            local MEM; MEM=$(safe_vmrss "$PID")
            TAG_MEM_KB[$TAG]=$(( MEM > ${TAG_MEM_KB[$TAG]:-0} ? MEM : ${TAG_MEM_KB[$TAG]:-0} ))
            ALL_TICKS_T0[$PID]=$(safe_pid_ticks "$PID")
            ALL_COMM[$PID]="$TAG"
        done
    }

    prescan_t0

    _add_known "xray"    $(pgrep -x xray 2>/dev/null)
    _add_known "proxy"   $(pgrep -f "$PROXY_SCRIPT" 2>/dev/null)
    _add_known "badvpn"  $(pgrep -x badvpn-udpgw 2>/dev/null)
    _add_known "stunnel" $(pgrep -x stunnel4 2>/dev/null; pgrep -x stunnel 2>/dev/null)

    sleep "$SAMPLE_INTERVAL"

    local SYS_T1
    SYS_T1=$(read_sys_stat)
    if [ -z "$SYS_T1" ]; then
        log "ERROR: no se pudo leer /proc/stat en T1 — abortando ciclo"
        return
    fi
    local SYS_TOTAL_T1 SYS_IDLE_T1
    SYS_TOTAL_T1=$(safe_int "$(echo "$SYS_T1" | awk '{print $1}')")
    SYS_IDLE_T1=$(safe_int  "$(echo "$SYS_T1" | awk '{print $2}')")

    local DELTA_SYS=$(( SYS_TOTAL_T1 - SYS_TOTAL_T0 ))
    local DELTA_IDLE=$(( SYS_IDLE_T1 - SYS_IDLE_T0 ))

    if [ "$DELTA_SYS" -le 0 ]; then
        log "SCAN: delta sistema <= 0 (${DELTA_SYS}) — tick inválido, abortando ciclo"
        return
    fi

    local DELTA_BUSY=$(( DELTA_SYS - DELTA_IDLE ))
    [ "$DELTA_BUSY" -lt 0 ] && DELTA_BUSY=0
    SYS_CPU_PCT=$(safe_pct "$DELTA_BUSY" "$DELTA_SYS")

    local TOTAL_RAM_KB
    TOTAL_RAM_KB=$(safe_int "$(awk '/MemTotal/{print $2}' /proc/meminfo 2>/dev/null)")
    [ "$TOTAL_RAM_KB" -le 0 ] && TOTAL_RAM_KB=1

    declare -A PID_DELTA
    declare -A PID_CPU_PCT

    for PID in "${!ALL_TICKS_T0[@]}"; do
        local T1; T1=$(safe_pid_ticks "$PID")
        local T0; T0=$(safe_int "${ALL_TICKS_T0[$PID]}")
        local DELTA=$(( T1 - T0 ))
        [ "$DELTA" -lt 0 ] && DELTA=0
        PID_DELTA[$PID]="$DELTA"
        PID_CPU_PCT[$PID]=$(safe_pct "$DELTA" "$DELTA_SYS")
    done

    TOP_PIDS_SORTED=$(for PID in "${!PID_DELTA[@]}"; do
        echo "${PID_DELTA[$PID]} $PID"
    done | sort -rn | head -"$TOP_N_PROCS" | awk '{print $2}')

    declare -A TAG_CPU_REAL
    local SCAN_LOG="SCAN sys_cpu=${SYS_CPU_PCT}%:"

    # ── CAPA 1 y 2: Servicios conocidos + fallback individual ─────────
    for PID in $TOP_PIDS_SORTED; do
        if is_self_pid "$PID"; then
            local SELF_COMM; SELF_COMM=$(cat "/proc/$PID/comm" 2>/dev/null || echo "watchdog")
            log "SELF-EXCL: PID $PID ($SELF_COMM) apareció en top-N — descartado"   # [H]
            continue
        fi

        local TAG="${PID_TAG[$PID]:-}"
        local COMM="${ALL_COMM[$PID]:-unknown}"
        local PID_CPU; PID_CPU=$(safe_int "${PID_CPU_PCT[$PID]:-0}")
        local VmRSS;   VmRSS=$(safe_vmrss "$PID")
        local PID_MEM; PID_MEM=$(safe_pct "$VmRSS" "$TOTAL_RAM_KB")

        if [ -n "$TAG" ]; then
            TAG_CPU_REAL[$TAG]=$(( ${TAG_CPU_REAL[$TAG]:-0} + PID_CPU ))
            TAG_MEM_KB[$TAG]=$(( VmRSS > ${TAG_MEM_KB[$TAG]:-0} ? VmRSS : ${TAG_MEM_KB[$TAG]:-0} ))
            SCAN_LOG="${SCAN_LOG} ${TAG}=${PID_CPU}%cpu/${PID_MEM}%mem"

            if [ "${TAG_CPU_REAL[$TAG]}" -gt "$CULPRIT_CPU" ]; then
                CULPRIT="$TAG"
                CULPRIT_CPU="${TAG_CPU_REAL[$TAG]}"
                CULPRIT_MEM=$(safe_pct "${TAG_MEM_KB[$TAG]}" "$TOTAL_RAM_KB")
            fi
        else
            SCAN_LOG="${SCAN_LOG} ${COMM}[${PID}]=${PID_CPU}%cpu/${PID_MEM}%mem"

            if [ "$PID_CPU" -ge "$FALLBACK_CPU_MIN" ]; then
                local FB_CPU_CTR_F="${FB_CPU_DIR}/pid_${PID}"
                local FB_CPU_CTR
                FB_CPU_CTR=$(safe_int "$(cat "$FB_CPU_CTR_F" 2>/dev/null)")
                FB_CPU_CTR=$(( FB_CPU_CTR + 1 ))
                echo "$FB_CPU_CTR" > "$FB_CPU_CTR_F"
                log "FALLBACK-CPU: ${COMM} (PID $PID) = ${PID_CPU}%cpu — ciclo ${FB_CPU_CTR}/${FALLBACK_CPU_CYCLES}"

                if [ "$FB_CPU_CTR" -ge "$FALLBACK_CPU_CYCLES" ]; then
                    if [ "$PID_CPU" -gt "$CULPRIT_CPU" ] || [ "$CULPRIT" = "unknown" ]; then
                        CULPRIT="fallback_cpu:${COMM}:${PID}"
                        CULPRIT_CPU="$PID_CPU"
                        CULPRIT_MEM="$PID_MEM"
                    fi
                fi
            else
                local FB_CPU_CTR_F="${FB_CPU_DIR}/pid_${PID}"
                if [ -f "$FB_CPU_CTR_F" ]; then
                    local CUR; CUR=$(safe_int "$(cat "$FB_CPU_CTR_F" 2>/dev/null)")
                    [ "$CUR" -gt 0 ] && echo $(( CUR - 1 )) > "$FB_CPU_CTR_F" || rm -f "$FB_CPU_CTR_F"
                fi
            fi

            if [ "$PID_MEM" -ge "$FALLBACK_RAM_MIN" ]; then
                local FB_RAM_CTR_F="${FB_RAM_DIR}/pid_${PID}"
                local FB_RAM_CTR
                FB_RAM_CTR=$(safe_int "$(cat "$FB_RAM_CTR_F" 2>/dev/null)")
                FB_RAM_CTR=$(( FB_RAM_CTR + 1 ))
                echo "$FB_RAM_CTR" > "$FB_RAM_CTR_F"
                log "FALLBACK-RAM: ${COMM} (PID $PID) = ${PID_MEM}%mem — ciclo ${FB_RAM_CTR}/${FALLBACK_RAM_CYCLES}"

                if [ "$FB_RAM_CTR" -ge "$FALLBACK_RAM_CYCLES" ] && [ "$CULPRIT" = "unknown" ]; then
                    CULPRIT="fallback_ram:${COMM}:${PID}"
                    CULPRIT_CPU="$PID_CPU"
                    CULPRIT_MEM="$PID_MEM"
                fi
            else
                local FB_RAM_CTR_F="${FB_RAM_DIR}/pid_${PID}"
                if [ -f "$FB_RAM_CTR_F" ]; then
                    local CUR; CUR=$(safe_int "$(cat "$FB_RAM_CTR_F" 2>/dev/null)")
                    [ "$CUR" -gt 0 ] && echo $(( CUR - 1 )) > "$FB_RAM_CTR_F" || rm -f "$FB_RAM_CTR_F"
                fi
            fi
        fi
    done

    log "$SCAN_LOG"

    # ── CAPA 3: Detección grupal ──────────────────────────────────────
    declare -A COMM_CPU_SUM
    declare -A COMM_PIDS_ALL

    for PID in "${!PID_DELTA[@]}"; do
        is_self_pid "$PID" && continue   # [F]
        [ -n "${PID_TAG[$PID]:-}" ] && continue
        local COMM="${ALL_COMM[$PID]:-}"
        [ -z "$COMM" ] && continue
        local PCPU; PCPU=$(safe_int "${PID_CPU_PCT[$PID]:-0}")
        [ "$PCPU" -eq 0 ] && continue
        COMM_CPU_SUM[$COMM]=$(( ${COMM_CPU_SUM[$COMM]:-0} + PCPU ))
        COMM_PIDS_ALL[$COMM]="${COMM_PIDS_ALL[$COMM]:-}${PID} "
    done

    local BEST_GROUP="" BEST_GROUP_CPU=0 BEST_GROUP_PIDS=""
    for COMM in "${!COMM_CPU_SUM[@]}"; do
        local GCPU; GCPU=$(safe_int "${COMM_CPU_SUM[$COMM]}")
        if [ "$GCPU" -gt "$BEST_GROUP_CPU" ]; then
            BEST_GROUP_CPU="$GCPU"
            BEST_GROUP="$COMM"
            BEST_GROUP_PIDS="${COMM_PIDS_ALL[$COMM]}"
        fi
    done

    if [ -n "$BEST_GROUP" ] && [ "$BEST_GROUP_CPU" -ge "$GROUP_CPU_MIN" ]; then
        local GRP_CTR_F="${GRP_DIR}/${BEST_GROUP}"
        local GRP_CTR
        GRP_CTR=$(safe_int "$(cat "$GRP_CTR_F" 2>/dev/null)")
        GRP_CTR=$(( GRP_CTR + 1 ))
        echo "$GRP_CTR" > "$GRP_CTR_F"

        local NPIDS
        NPIDS=$(echo "$BEST_GROUP_PIDS" | wc -w)
        log "GROUP: ${BEST_GROUP} = ${BEST_GROUP_CPU}%cpu (${NPIDS} PIDs) — ciclo ${GRP_CTR}/${GROUP_CPU_CYCLES}"

        if [ "$GRP_CTR" -ge "$GROUP_CPU_CYCLES" ]; then
            if [ "$BEST_GROUP_CPU" -gt "$CULPRIT_CPU" ] || [ "$CULPRIT" = "unknown" ]; then
                CULPRIT="group:${BEST_GROUP}"
                CULPRIT_CPU="$BEST_GROUP_CPU"
                CULPRIT_GROUP_PIDS="$BEST_GROUP_PIDS"
                log "GROUP: culprit → group:${BEST_GROUP} (${BEST_GROUP_CPU}%cpu, ${NPIDS} PIDs: ${BEST_GROUP_PIDS})"
            fi
        fi
    fi

    for F in "${GRP_DIR}"/*; do
        [ -f "$F" ] || continue
        local GNAME="${F##*/}"
        local GCPU; GCPU=$(safe_int "${COMM_CPU_SUM[$GNAME]:-0}")
        if [ "$GCPU" -lt "$GROUP_CPU_MIN" ]; then
            local CUR; CUR=$(safe_int "$(cat "$F" 2>/dev/null)")
            [ "$CUR" -gt 0 ] && echo $(( CUR - 1 )) > "$F" || rm -f "$F"
        fi
    done

    # ── CAPA 4: Selector de emergencia — [G] filtra SELF_PIDS ─────────
    if [ "$CULPRIT" = "unknown" ] && [ "$SYS_CPU_PCT" -ge "$CPU_WARN" ]; then
        local BEST_PID="" BEST_DELTA=0
        for PID in $TOP_PIDS_SORTED; do
            if is_self_pid "$PID"; then
                local SELF_COMM; SELF_COMM=$(cat "/proc/$PID/comm" 2>/dev/null || echo "watchdog")
                log "EMERGENCY SELF-EXCL: PID $PID ($SELF_COMM) descartado como candidato de emergencia"
                continue
            fi
            [ -n "${PID_TAG[$PID]:-}" ] && continue
            local D; D=$(safe_int "${PID_DELTA[$PID]:-0}")
            if [ "$D" -gt "$BEST_DELTA" ]; then
                BEST_DELTA="$D"
                BEST_PID="$PID"
            fi
        done

        if [ -n "$BEST_PID" ]; then
            local B_COMM="${ALL_COMM[$BEST_PID]:-unknown}"
            local B_CPU; B_CPU=$(safe_int "${PID_CPU_PCT[$BEST_PID]:-0}")
            local B_VmRSS; B_VmRSS=$(safe_vmrss "$BEST_PID")
            local B_MEM;   B_MEM=$(safe_pct "$B_VmRSS" "$TOTAL_RAM_KB")

            local EM_CTR_F="${FB_CPU_DIR}/pid_${BEST_PID}"
            local EM_CTR
            EM_CTR=$(safe_int "$(cat "$EM_CTR_F" 2>/dev/null)")
            EM_CTR=$(( EM_CTR + 1 ))
            echo "$EM_CTR" > "$EM_CTR_F"

            log "EMERGENCY: top no-safe → ${B_COMM} [PID ${BEST_PID}] = ${B_CPU}%cpu — ciclo ${EM_CTR}/${FALLBACK_CPU_CYCLES}"

            if [ "$EM_CTR" -ge "$FALLBACK_CPU_CYCLES" ]; then
                CULPRIT="fallback_cpu:${B_COMM}:${BEST_PID}"
                CULPRIT_CPU="$B_CPU"
                CULPRIT_MEM="$B_MEM"
                log "EMERGENCY: culprit forzado → ${CULPRIT}"
            fi
        else
            log "EMERGENCY: no se encontró proceso candidato (todos son safe, conocidos o propios del watchdog)"
        fi
    fi

    log "RESULT: culprit=${CULPRIT} (cpu=${CULPRIT_CPU}% mem=${CULPRIT_MEM}%) sys_cpu=${SYS_CPU_PCT}%"

    # ── Construir EXTRA_CULPRITS para multi-kill (v4.7) ───────────────
    EXTRA_CULPRITS=""

    for COMM in $(for K in "${!COMM_CPU_SUM[@]}"; do
                      echo "${COMM_CPU_SUM[$K]} $K"
                  done | sort -rn | awk '{print $2}'); do
        local GCPU; GCPU=$(safe_int "${COMM_CPU_SUM[$COMM]}")
        [ "$GCPU" -lt "$GROUP_CPU_MIN" ] && continue
        local GKEY="group:${COMM}"
        [ "$GKEY" = "$CULPRIT" ] && continue
        EXTRA_CULPRITS="${EXTRA_CULPRITS}${GKEY}|${COMM_PIDS_ALL[$COMM]}|${GCPU} "
    done

    for PID in $TOP_PIDS_SORTED; do
        is_self_pid "$PID" && continue   # [F]
        [ -n "${PID_TAG[$PID]:-}" ] && continue
        local PCPU; PCPU=$(safe_int "${PID_CPU_PCT[$PID]:-0}")
        [ "$PCPU" -lt "$FALLBACK_CPU_MIN" ] && continue
        local FCOMM="${ALL_COMM[$PID]:-unknown}"
        local FKEY="fallback_cpu:${FCOMM}:${PID}"
        [ "$FKEY" = "$CULPRIT" ] && continue
        EXTRA_CULPRITS="${EXTRA_CULPRITS}${FKEY}||${PCPU} "
    done

    # ── Limpiar contadores huérfanos ──────────────────────────────────
    for F in "${FB_CPU_DIR}"/pid_* "${FB_RAM_DIR}"/pid_*; do
        [ -f "$F" ] || continue
        local FPID="${F##*pid_}"
        [ -d "/proc/$FPID" ] || rm -f "$F"
    done
}

# ══════════════════════════════════════════════════════════════════════
# Acciones por servicio conocido
# ══════════════════════════════════════════════════════════════════════
do_restart_xray() {
    log "ACTION [xray]: x-ui restart-xray"
    x-ui restart-xray >> "$LOG" 2>&1
    local EC=$?
    [ "$EC" -eq 0 ] && log "OK [xray]: reiniciado" || log "ERROR [xray]: fallo (exit $EC)"
    _set_cd "xray"
}

do_restart_proxy() {
    log "ACTION [proxy]: reiniciando PDirect.py"
    pkill -f "$PROXY_SCRIPT" 2>/dev/null; sleep 2
    nohup python3 "$PROXY_SCRIPT" "$PROXY_PORT" > /root/nohup.out 2>&1 &
    sleep 2
    pgrep -f "$PROXY_SCRIPT" > /dev/null \
        && log "OK [proxy]: PDirect.py reiniciado (PID $(pgrep -f "$PROXY_SCRIPT" | head -1))" \
        || log "ERROR [proxy]: no arrancó"
    _set_cd "proxy"
}

do_restart_badvpn() {
    log "ACTION [badvpn]: reiniciando instancias 7200 y 7300"
    pkill -f "badvpn-udpgw" 2>/dev/null
    screen -S badvpn   -X quit 2>/dev/null
    screen -S badUDP72 -X quit 2>/dev/null
    sleep 2
    screen -dmS badvpn   /usr/bin/badvpn-udpgw --listen-addr 127.0.0.1:7300 \
        --max-clients 1000 --max-connections-for-client 10
    screen -dmS badUDP72 /usr/bin/badvpn-udpgw --listen-addr 127.0.0.1:7200 \
        --max-clients 1000 --max-connections-for-client 10
    sleep 2
    pgrep -f "badvpn-udpgw" > /dev/null \
        && log "OK [badvpn]: instancias reiniciadas" \
        || log "ERROR [badvpn]: no arrancó"
    _set_cd "badvpn"
}

do_restart_stunnel() {
    log "ACTION [stunnel]: systemctl restart stunnel4"
    systemctl restart stunnel4 >> "$LOG" 2>&1
    local EC=$?
    [ "$EC" -eq 0 ] && log "OK [stunnel]: reiniciado" || log "ERROR [stunnel]: fallo (exit $EC)"
    _set_cd "stunnel"
}

# ══════════════════════════════════════════════════════════════════════
# Acción escalonada fallback: SIGTERM → SIGKILL
# ══════════════════════════════════════════════════════════════════════
do_kill_fallback() {
    local TYPE="$1"
    local FB_NAME="$2"
    local FB_PID="$3"

    # [F] Guardia final: nunca matar PIDs propios
    if is_self_pid "$FB_PID"; then
        log "ABORT [fallback-${TYPE}]: PID $FB_PID ($FB_NAME) es PID propio del watchdog — acción cancelada"
        return
    fi

    local CTR_DIR
    [ "$TYPE" = "cpu" ] && CTR_DIR="$FB_CPU_DIR" || CTR_DIR="$FB_RAM_DIR"
    local FB_CTR_F="${CTR_DIR}/pid_${FB_PID}"
    local FB_CTR; FB_CTR=$(safe_int "$(cat "$FB_CTR_F" 2>/dev/null)")
    local THRESH
    [ "$TYPE" = "cpu" ] && THRESH=$FALLBACK_CPU_CYCLES || THRESH=$FALLBACK_RAM_CYCLES

    if ! kill -0 "$FB_PID" 2>/dev/null; then
        log "FALLBACK-${TYPE^^}: PID $FB_PID ($FB_NAME) ya no existe"
        rm -f "$FB_CTR_F"; _set_cd "fallback_${TYPE}_${FB_PID}"
        return
    fi

    if [ "$FB_CTR" -eq "$THRESH" ]; then
        log "ACTION [fallback-${TYPE}]: SIGTERM → $FB_NAME (PID $FB_PID)"
        kill -15 "$FB_PID" 2>/dev/null
        echo $(( FB_CTR + 1 )) > "$FB_CTR_F"
        log "INFO: esperando próximo ciclo para verificar si terminó"
        return
    fi

    if kill -0 "$FB_PID" 2>/dev/null; then
        log "ACTION [fallback-${TYPE}]: SIGKILL → $FB_NAME (PID $FB_PID) [ignoró SIGTERM]"
        kill -9 "$FB_PID" 2>/dev/null
        sleep 1
        kill -0 "$FB_PID" 2>/dev/null \
            && log "ERROR [fallback-${TYPE}]: PID $FB_PID no respondió a SIGKILL — posible hilo kernel" \
            || { log "OK [fallback-${TYPE}]: $FB_NAME terminado con SIGKILL"; rm -f "$FB_CTR_F"; }
    else
        log "OK [fallback-${TYPE}]: $FB_NAME (PID $FB_PID) terminó con SIGTERM"
        rm -f "$FB_CTR_F"
    fi
    _set_cd "fallback_${TYPE}_${FB_PID}"
}

# ══════════════════════════════════════════════════════════════════════
# Acción grupal: SIGTERM → SIGKILL
# ══════════════════════════════════════════════════════════════════════
do_kill_group() {
    local GRP_NAME="$1"
    local GRP_PIDS="$2"
    local GRP_CTR_F="${GRP_DIR}/${GRP_NAME}"
    local GRP_CTR; GRP_CTR=$(safe_int "$(cat "$GRP_CTR_F" 2>/dev/null)")

    local ALIVE_PIDS=""
    for PID in $GRP_PIDS; do
        if is_self_pid "$PID"; then
            log "ABORT [group]: PID $PID es PID propio del watchdog — excluido del kill grupal"
            continue
        fi
        kill -0 "$PID" 2>/dev/null && ALIVE_PIDS="${ALIVE_PIDS}${PID} "
    done

    if [ -z "$ALIVE_PIDS" ]; then
        log "GROUP: todos los PIDs de '${GRP_NAME}' ya terminaron — limpiando"
        rm -f "$GRP_CTR_F"; _set_cd "group_${GRP_NAME}"; return
    fi

    local N_ALIVE
    N_ALIVE=$(echo "$ALIVE_PIDS" | wc -w)

    if [ "$GRP_CTR" -le "$GROUP_CPU_CYCLES" ]; then
        log "ACTION [group]: SIGTERM → grupo '${GRP_NAME}' (${N_ALIVE} PIDs vivos: ${ALIVE_PIDS})"
        for PID in $ALIVE_PIDS; do
            kill -15 "$PID" 2>/dev/null \
                && log "  SIGTERM → ${GRP_NAME} [PID $PID]" \
                || log "  SIGTERM falló → ${GRP_NAME} [PID $PID] (ya terminó?)"
        done
        echo $(( GRP_CTR + 1 )) > "$GRP_CTR_F"
        log "INFO [group]: esperando próximo ciclo para verificar sobrevivientes"
    else
        log "ACTION [group]: SIGKILL → sobrevivientes de '${GRP_NAME}' (${N_ALIVE} PIDs)"
        local KILLED=0 GONE=0
        for PID in $ALIVE_PIDS; do
            if kill -0 "$PID" 2>/dev/null; then
                kill -9 "$PID" 2>/dev/null; sleep 0
                if kill -0 "$PID" 2>/dev/null; then
                    log "  ERROR: ${GRP_NAME} [PID $PID] no respondió a SIGKILL — posible hilo kernel"
                else
                    log "  SIGKILL → ${GRP_NAME} [PID $PID] OK"; (( KILLED++ ))
                fi
            else
                log "  OK: ${GRP_NAME} [PID $PID] ya terminó (respondió SIGTERM)"; (( GONE++ ))
            fi
        done
        log "OK [group]: '${GRP_NAME}' — ${KILLED} matados con SIGKILL, ${GONE} terminaron solos"
        rm -f "$GRP_CTR_F"
    fi
    _set_cd "group_${GRP_NAME}"
}

# ══════════════════════════════════════════════════════════════════════
# dispatch_action()
# ══════════════════════════════════════════════════════════════════════
dispatch_action() {
    local REASON="$1"
    log "TRIGGER: $REASON → culprit=${CULPRIT}"

    case "$CULPRIT" in
        xray)
            if [ "$FORCE_KILL" -eq 0 ]; then
                _in_cd "xray" "$COOLDOWN_KNOWN" \
                    && { log "CD [xray]: en cooldown ($(_cd_remaining xray $COOLDOWN_KNOWN)s restantes)"; return; }
            else
                log "FORCE: ignorando cooldown para xray"
            fi
            do_restart_xray ;;

        proxy)
            if [ "$FORCE_KILL" -eq 0 ]; then
                _in_cd "proxy" "$COOLDOWN_KNOWN" \
                    && { log "CD [proxy]: en cooldown"; return; }
            else
                log "FORCE: ignorando cooldown para proxy"
            fi
            do_restart_proxy ;;

        badvpn)
            if [ "$FORCE_KILL" -eq 0 ]; then
                _in_cd "badvpn" "$COOLDOWN_KNOWN" \
                    && { log "CD [badvpn]: en cooldown"; return; }
            else
                log "FORCE: ignorando cooldown para badvpn"
            fi
            do_restart_badvpn ;;

        stunnel)
            if [ "$FORCE_KILL" -eq 0 ]; then
                _in_cd "stunnel" "$COOLDOWN_KNOWN" \
                    && { log "CD [stunnel]: en cooldown"; return; }
            else
                log "FORCE: ignorando cooldown para stunnel"
            fi
            do_restart_stunnel ;;

        group:*)
            local GRP_NAME; GRP_NAME=$(echo "$CULPRIT" | cut -d: -f2)
            if [ "$FORCE_KILL" -eq 0 ]; then
                _in_cd "group_${GRP_NAME}" "$COOLDOWN_GROUP" \
                    && { log "CD [group]: '${GRP_NAME}' en cooldown ($(_cd_remaining "group_${GRP_NAME}" $COOLDOWN_GROUP)s restantes)"; return; }
            else
                log "FORCE: ignorando cooldown para group:${GRP_NAME}"
                echo "$GROUP_CPU_CYCLES" > "${GRP_DIR}/${GRP_NAME}"
            fi
            do_kill_group "$GRP_NAME" "$CULPRIT_GROUP_PIDS" ;;

        fallback_cpu:*)
            local FB_NAME; FB_NAME=$(echo "$CULPRIT" | cut -d: -f2)
            local FB_PID;  FB_PID=$(echo  "$CULPRIT" | cut -d: -f3)
            if [ "$FORCE_KILL" -eq 0 ]; then
                _in_cd "fallback_cpu_${FB_PID}" "$COOLDOWN_FALLBACK" \
                    && { log "CD [fallback-cpu]: $FB_NAME en cooldown"; return; }
            else
                log "FORCE: ignorando cooldown para fallback_cpu:${FB_NAME}[${FB_PID}]"
                echo "$FALLBACK_CPU_CYCLES" > "${FB_CPU_DIR}/pid_${FB_PID}"
            fi
            do_kill_fallback "cpu" "$FB_NAME" "$FB_PID" ;;

        fallback_ram:*)
            local FB_NAME; FB_NAME=$(echo "$CULPRIT" | cut -d: -f2)
            local FB_PID;  FB_PID=$(echo  "$CULPRIT" | cut -d: -f3)
            if [ "$FORCE_KILL" -eq 0 ]; then
                _in_cd "fallback_ram_${FB_PID}" "$COOLDOWN_FALLBACK" \
                    && { log "CD [fallback-ram]: $FB_NAME en cooldown"; return; }
            else
                log "FORCE: ignorando cooldown para fallback_ram:${FB_NAME}[${FB_PID}]"
                echo "$FALLBACK_RAM_CYCLES" > "${FB_RAM_DIR}/pid_${FB_PID}"
            fi
            do_kill_fallback "ram" "$FB_NAME" "$FB_PID" ;;

        # ── [I/J/K] unknown con CPU alta → estrategia escalonada ──────
        # Este caso antes era: log WARN + no hacer nada.
        # Ahora: contador de ciclos → level1 → verificar → level2.
        unknown)
            log "WARN: culprit=unknown — evaluando estrategia por CPU=${SYS_CPU_PCT}%"
            return ;;   # dispatch_action no maneja unknown directamente
                        # la lógica de unknown está en el bloque MAIN abajo
    esac
}

# ══════════════════════════════════════════════════════════════════════
# MAIN
# ══════════════════════════════════════════════════════════════════════
RAM_CTR=$(safe_int "$(cat "$RAM_COUNTER_FILE" 2>/dev/null)")
CPU_CTR=$(safe_int "$(cat "$CPU_COUNTER_FILE" 2>/dev/null)")
UNKNOWN_CTR=$(safe_int "$(cat "$UNKNOWN_CTR_FILE" 2>/dev/null)")   # [I]

RAM_PCT=$(safe_int "$(free 2>/dev/null | awk '/^Mem:/ {
    total=$2; avail=$7
    if (total > 0) printf "%.0f", (total-avail)/total * 100
    else print 0
}')")

log "INFO: RAM=${RAM_PCT}% | ctrs RAM=${RAM_CTR} CPU=${CPU_CTR} UNKNOWN=${UNKNOWN_CTR} | iniciando scan..."

identify_culprit

log "INFO: RAM=${RAM_PCT}% CPU_real=${SYS_CPU_PCT}% | culprit=${CULPRIT}"

# ── CPU crítica: FORCE_KILL + multi-kill + re-scan ────────────────────
if [ "$SYS_CPU_PCT" -ge "$CPU_CRIT" ]; then
    FORCE_KILL=1
    log "OVERRIDE: CPU crítica (${SYS_CPU_PCT}%>=${CPU_CRIT}%) — FORCE_KILL=1, cooldowns IGNORADOS"

    if [[ "$CULPRIT" == fallback_cpu:* ]]; then
        FB_PID_CRIT=$(echo "$CULPRIT" | cut -d: -f3)
        FB_COMM_CRIT=$(echo "$CULPRIT" | cut -d: -f2)
        echo "$FALLBACK_CPU_CYCLES" > "${FB_CPU_DIR}/pid_${FB_PID_CRIT}"
        log "OVERRIDE: forzando ciclos para fallback ${FB_COMM_CRIT} [PID ${FB_PID_CRIT}]"
    elif [[ "$CULPRIT" == group:* ]]; then
        GRP_NAME_CRIT=$(echo "$CULPRIT" | cut -d: -f2)
        echo "$GROUP_CPU_CYCLES" > "${GRP_DIR}/${GRP_NAME_CRIT}"
        log "OVERRIDE: forzando ciclos para group '${GRP_NAME_CRIT}' (PIDs: ${CULPRIT_GROUP_PIDS})"
    fi

    if [ "$CULPRIT" != "unknown" ]; then
        dispatch_action "CPU crítica (${SYS_CPU_PCT}%>=${CPU_CRIT}%)"

        # Multi-kill: hasta 2 culprits secundarios
        MAX_EXTRA=2; EXTRA_COUNT=0
        SAVED_CULPRIT="$CULPRIT"
        SAVED_CULPRIT_CPU="$CULPRIT_CPU"
        SAVED_CULPRIT_GROUP_PIDS="$CULPRIT_GROUP_PIDS"

        for ENTRY in $EXTRA_CULPRITS; do
            [ "$EXTRA_COUNT" -ge "$MAX_EXTRA" ] && break
            CULPRIT=$(echo "$ENTRY"            | cut -d'|' -f1)
            CULPRIT_GROUP_PIDS=$(echo "$ENTRY" | cut -d'|' -f2)
            CULPRIT_CPU=$(safe_int "$(echo "$ENTRY" | cut -d'|' -f3)")

            log "MULTI-KILL [$(( EXTRA_COUNT + 1 ))]: atacando culprit adicional → ${CULPRIT} (${CULPRIT_CPU}%cpu)"

            if [[ "$CULPRIT" == fallback_cpu:* ]]; then
                echo "$FALLBACK_CPU_CYCLES" > "${FB_CPU_DIR}/pid_$(echo "$CULPRIT" | cut -d: -f3)"
            elif [[ "$CULPRIT" == group:* ]]; then
                echo "$GROUP_CPU_CYCLES" > "${GRP_DIR}/$(echo "$CULPRIT" | cut -d: -f2)"
            fi

            dispatch_action "MULTI-KILL extra (CPU crítica)"
            (( EXTRA_COUNT++ ))
        done

        CULPRIT="$SAVED_CULPRIT"
        CULPRIT_CPU="$SAVED_CULPRIT_CPU"
        CULPRIT_GROUP_PIDS="$SAVED_CULPRIT_GROUP_PIDS"
        [ "$EXTRA_COUNT" -gt 0 ] && log "MULTI-KILL: ${EXTRA_COUNT} culprits adicionales atacados"

        # Re-scan inmediato post-kill
        log "RE-SCAN: esperando 3s post-kill y re-evaluando CPU..."
        sleep 3
        identify_culprit
        log "RE-SCAN RESULT: CPU=${SYS_CPU_PCT}% culprit=${CULPRIT}"

        if [ "$SYS_CPU_PCT" -ge "$CPU_CRIT" ] && [ "$CULPRIT" != "unknown" ]; then
            log "RE-SCAN: CPU sigue crítica (${SYS_CPU_PCT}%) — segunda ronda de kills"
            if [[ "$CULPRIT" == fallback_cpu:* ]]; then
                echo "$FALLBACK_CPU_CYCLES" > "${FB_CPU_DIR}/pid_$(echo "$CULPRIT" | cut -d: -f3)"
            elif [[ "$CULPRIT" == group:* ]]; then
                echo "$GROUP_CPU_CYCLES" > "${GRP_DIR}/$(echo "$CULPRIT" | cut -d: -f2)"
            fi
            dispatch_action "Re-scan CPU crítica (${SYS_CPU_PCT}%)"
        elif [ "$SYS_CPU_PCT" -lt "$CPU_WARN" ]; then
            log "RE-SCAN: ✅ CPU normalizada a ${SYS_CPU_PCT}% — amenaza contenida"
            echo "0" > "$CPU_COUNTER_FILE"
            echo "0" > "$UNKNOWN_CTR_FILE"
        else
            log "RE-SCAN: CPU en ${SYS_CPU_PCT}% (bajo el crítico) — monitoreando"
        fi
    fi

    FORCE_KILL=0
fi

# ── RAM crítica ───────────────────────────────────────────────────────
if [ "$RAM_PCT" -ge "$RAM_CRIT" ]; then
    dispatch_action "RAM crítica (${RAM_PCT}%>=${RAM_CRIT}%)"
fi

# ── Contadores sostenidos CPU ─────────────────────────────────────────
if [ "$SYS_CPU_PCT" -ge "$CPU_WARN" ]; then
    CPU_CTR=$(( CPU_CTR + 1 ))
    echo "$CPU_CTR" > "$CPU_COUNTER_FILE"
    log "WARN: CPU alta (${SYS_CPU_PCT}%) — ciclo ${CPU_CTR}/${CYCLES_REQUIRED}"
    [ "$CPU_CTR" -ge "$CYCLES_REQUIRED" ] && [ "$CULPRIT" != "unknown" ] && \
        dispatch_action "CPU sostenida (${SYS_CPU_PCT}% x ${CPU_CTR} ciclos)"
else
    if [ "$CPU_CTR" -gt 0 ]; then
        CPU_CTR=$(( CPU_CTR - 1 ))
        echo "$CPU_CTR" > "$CPU_COUNTER_FILE"
        log "INFO: CPU bajó a ${SYS_CPU_PCT}% — contador decrementado a ${CPU_CTR}"
    fi
fi

# ── Contadores sostenidos RAM ─────────────────────────────────────────
if [ "$RAM_PCT" -ge "$RAM_WARN" ]; then
    RAM_CTR=$(( RAM_CTR + 1 ))
    echo "$RAM_CTR" > "$RAM_COUNTER_FILE"
    log "WARN: RAM alta (${RAM_PCT}%) — ciclo ${RAM_CTR}/${CYCLES_REQUIRED}"
    [ "$RAM_CTR" -ge "$CYCLES_REQUIRED" ] && \
        dispatch_action "RAM sostenida (${RAM_PCT}% x ${RAM_CTR} ciclos)"
else
    if [ "$RAM_CTR" -gt 0 ]; then
        RAM_CTR=$(( RAM_CTR - 1 ))
        echo "$RAM_CTR" > "$RAM_COUNTER_FILE"
        log "INFO: RAM bajó a ${RAM_PCT}% — contador decrementado a ${RAM_CTR}"
    fi
fi

# ── Fallback/grupo sostenido (sin CPU crítica) ────────────────────────
if [[ "$CULPRIT" == fallback_cpu:* ]] || \
   [[ "$CULPRIT" == fallback_ram:* ]] || \
   [[ "$CULPRIT" == group:* ]]; then
    dispatch_action "Proceso/grupo externo sostenido detectado"
fi

# ══════════════════════════════════════════════════════════════════════
# [I/J/K] Estrategia escalonada ante culprit=unknown con CPU alta
#
# Flujo:
#   1. Si CPU >= CPU_WARN Y culprit=unknown → incrementar UNKNOWN_CTR
#   2. Si UNKNOWN_CTR >= UNKNOWN_CYCLES_REQUIRED:
#      a. Level1: reiniciar servicios propios (si cooldown lo permite)
#      b. Verificar CPU post-level1
#      c. Si CPU sigue >= CPU_CRIT Y level1 ya corrió: level2 (drop_caches)
#   3. Si CPU < CPU_WARN O culprit != unknown → resetear UNKNOWN_CTR
#
# Este bloque va DESPUÉS de todos los otros porque:
#   - Si hay culprit identificado, ya fue manejado arriba
#   - Solo llega aquí si después de todas las capas sigue unknown
# ══════════════════════════════════════════════════════════════════════
if [ "$CULPRIT" = "unknown" ] && [ "$SYS_CPU_PCT" -ge "$CPU_WARN" ]; then
    UNKNOWN_CTR=$(( UNKNOWN_CTR + 1 ))
    echo "$UNKNOWN_CTR" > "$UNKNOWN_CTR_FILE"
    log "UNKNOWN: CPU=${SYS_CPU_PCT}% sin culprit — ciclo ${UNKNOWN_CTR}/${UNKNOWN_CYCLES_REQUIRED}"

    if [ "$UNKNOWN_CTR" -ge "$UNKNOWN_CYCLES_REQUIRED" ]; then
        log "UNKNOWN: umbral alcanzado (${UNKNOWN_CTR} ciclos) — activando protocolo escalonado"

        # Level 1: reinicio preventivo de servicios propios
        if _in_cd "unknown_l1" "$COOLDOWN_UNKNOWN_L1"; then
            local REM; REM=$(_cd_remaining "unknown_l1" "$COOLDOWN_UNKNOWN_L1")
            log "UNKNOWN-L1: en cooldown (${REM}s restantes) — saltando level1"
        else
            do_unknown_level1 "$SYS_CPU_PCT"

            # Verificar si después del level1 la CPU sigue crítica para level2
            # La verificación de CPU fue hecha dentro de do_unknown_level1()
            # Aquí re-leemos UNKNOWN_CTR por si do_unknown_level1() lo reseteó
            UNKNOWN_CTR=$(safe_int "$(cat "$UNKNOWN_CTR_FILE" 2>/dev/null)")

            if [ "$UNKNOWN_CTR" -gt 0 ] && [ "$SYS_CPU_PCT" -ge "$CPU_CRIT" ]; then
                # Level 2: liberación de cache del kernel
                if _in_cd "unknown_l2" "$COOLDOWN_UNKNOWN_L2"; then
                    local REM2; REM2=$(_cd_remaining "unknown_l2" "$COOLDOWN_UNKNOWN_L2")
                    log "UNKNOWN-L2: en cooldown (${REM2}s restantes) — saltando level2"
                else
                    do_unknown_level2 "$SYS_CPU_PCT"
                fi
            fi
        fi
    fi

else
    # CPU normalizó o se identificó culprit → resetear contador unknown
    if [ "$UNKNOWN_CTR" -gt 0 ]; then
        log "INFO: reseteando contador unknown (CPU=${SYS_CPU_PCT}% culprit=${CULPRIT})"
        echo "0" > "$UNKNOWN_CTR_FILE"
    fi
fi

log "INFO: ciclo completado → sin más acciones pendientes"
exit 0
WDEOF

chmod +x /root/xray_watchdog.sh

# ── Registrar cron — cada minuto ─────────────────────────────────────
CRON_TMP_WD=$(mktemp)
crontab -l 2>/dev/null > "$CRON_TMP_WD" || true
sed -i '/xray_watchdog\.sh/d' "$CRON_TMP_WD"
echo "* * * * * /root/xray_watchdog.sh" >> "$CRON_TMP_WD"
crontab "$CRON_TMP_WD"
rm -f "$CRON_TMP_WD"

# ── Systemd timer 30s (opcional, desactivado por defecto) ────────────
cat > /etc/systemd/system/watchdog-vpn.service <<'SVEOF'
