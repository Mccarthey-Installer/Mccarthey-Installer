# ===========================
# 5. WATCHDOG v4.6
#
#   NUEVO en v4.6 — Detección grupal (carga distribuida):
#
#   PROBLEMA REAL:
#     10 procesos dd a ~5% cada uno → total 100% CPU.
#     Ninguno supera FALLBACK_CPU_MIN individualmente.
#     Resultado anterior: culprit=unknown → sin acción. VPS saturado.
#
#   SOLUCIÓN — 3 capas de detección en orden:
#
#   CAPA 1 (existente): Servicios conocidos (xray, proxy, badvpn, stunnel).
#     Si uno de ellos supera su umbral → acción directa.
#
#   CAPA 2 (existente, mejorada): Fallback individual.
#     Proceso único no-safe con CPU >= FALLBACK_CPU_MIN (20%) sostenida.
#     Ejemplo: 1 proceso yes a 95% → detectado en ciclo 2.
#
#   CAPA 3 (NUEVA): Detección grupal por nombre (comm).
#     Suma la CPU de TODOS los PIDs con el mismo nombre de proceso.
#     Si el grupo supera GROUP_CPU_MIN (30%) por GROUP_CPU_CYCLES ciclos:
#       → culprit = "group:<nombre>"
#       → SIGTERM a TODOS los PIDs del grupo simultáneamente.
#       → SIGKILL en el siguiente ciclo a los que sobrevivieron.
#     Ejemplo: 10x dd a 5% cada uno → grupo "dd" = 50% → SIGTERM a los 10.
#     Ejemplo: 5x wget a 8% cada uno → grupo "wget" = 40% → SIGTERM a los 5.
#
#   CAPA 4 (existente, ajustada): Selector de emergencia.
#     Último recurso: si culprit sigue unknown con CPU >= CPU_WARN,
#     toma el proceso con más ticks (sin importar umbral) y lo acumula.
#     Garantía dura: con VPS al 96% siempre hay alguna acción.
#
#   OVERRIDE v4.5 (mantenido):
#     CPU crítica (>=75%) + fallback/group identificado → acción INMEDIATA.
#     Sin esperar ciclo 2.
#
#   Frecuencia: cron cada minuto.
#   Timer systemd 30s disponible pero desactivado por defecto.
# ===========================
echo "Instalando Watchdog v4.6..."

cat > /root/xray_watchdog.sh << 'EOF'
#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════
#   WATCHDOG v4.6
#
#   Capas de detección (en orden):
#     1. Servicios conocidos     → restart directo
#     2. Fallback individual     → SIGTERM/SIGKILL (umbral 20%)
#     3. Detección grupal        → SIGTERM/SIGKILL a todo el grupo (NUEVO)
#     4. Selector emergencia     → proceso de mayor ticks sin umbral
#
#   La capa 3 resuelve: N procesos del mismo nombre con CPU baja
#   individual pero alta en suma. Cubre carga distribuida real.
#
#   Cron: * * * * * /root/xray_watchdog.sh
# ═══════════════════════════════════════════════════════════════════════

LOG="/var/log/xray_watchdog.log"
LOCK="/tmp/xray_watchdog.lock"

# ── Umbrales sistema ──────────────────────────────────────────────────
RAM_WARN=70
RAM_CRIT=80
CPU_WARN=70
CPU_CRIT=75
CYCLES_REQUIRED=2

# ── Umbrales fallback individual ──────────────────────────────────────
# Un solo proceso no-safe que supere este % individualmente.
FALLBACK_CPU_MIN=20
FALLBACK_CPU_CYCLES=2

# ── Umbrales detección grupal (NUEVO v4.6) ────────────────────────────
# Suma de CPU de todos los PIDs con el mismo nombre de proceso.
# Ejemplo: 10x dd a 5% cada uno = 50% → supera GROUP_CPU_MIN → acción.
GROUP_CPU_MIN=30
GROUP_CPU_CYCLES=2

# ── Umbrales fallback RAM ─────────────────────────────────────────────
FALLBACK_RAM_MIN=25
FALLBACK_RAM_CYCLES=2

# ── Parámetros de scan ────────────────────────────────────────────────
TOP_N_PROCS=10
SAMPLE_INTERVAL=2

# ── Directorios de estado ─────────────────────────────────────────────
STATE_DIR="/tmp/watchdog_state"
CD_DIR="${STATE_DIR}/cooldown"
FB_CPU_DIR="${STATE_DIR}/fb_cpu"
FB_RAM_DIR="${STATE_DIR}/fb_ram"
GRP_DIR="${STATE_DIR}/groups"

mkdir -p "$CD_DIR" "$FB_CPU_DIR" "$FB_RAM_DIR" "$GRP_DIR"

RAM_COUNTER_FILE="${STATE_DIR}/counter_ram"
CPU_COUNTER_FILE="${STATE_DIR}/counter_cpu"

# ── Cooldown por servicio/proceso ─────────────────────────────────────
COOLDOWN_KNOWN=900
COOLDOWN_FALLBACK=600
COOLDOWN_GROUP=600

# ── Variable global para PIDs del grupo culpable ──────────────────────
# Asignada en identify_culprit(), leída en do_kill_group().
CULPRIT_GROUP_PIDS=""

# ── Procesos NUNCA afectados por fallback ni grupo ────────────────────
SAFE_PROCS_RE="^(systemd|systemd-.*|init|sshd|bash|sh|dash|zsh|fish|\
kthread|ksoftirqd|kworker|migration|rcu_.*|watchdog|\
ps|awk|grep|sed|cut|head|tail|cat|xargs|sleep|find|wc|sort|uniq|\
cron|crond|atd|rsyslogd|syslogd|systemd-journald|\
dbus-daemon|dbus-broker|udevd|systemd-udevd|\
NetworkManager|networkd|systemd-networkd|systemd-resolved|\
logind|systemd-logind|accounts-daemon|polkitd|\
snapd|containerd|dockerd|docker-proxy|multipathd|\
chronyd|ntpd|systemd-timesyncd|\
stunnel4|stunnel|badvpn-udpgw|python3|xray|\
xray_watchdog|clean-vps|rc.local|x-ui)$"

PROXY_SCRIPT="/etc/MCCARTHEY/PDirect.py"
PROXY_PORT=80

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$LOG"; }

exec 200>"$LOCK"
flock -n 200 || exit 0

# ══════════════════════════════════════════════════════════════════════
# Helpers cooldown
# ══════════════════════════════════════════════════════════════════════
_cd_file()  { echo "${CD_DIR}/$(echo "$1" | tr ':/' '__')"; }
_in_cd() {
    local F; F=$(_cd_file "$1")
    [ -f "$F" ] || return 1
    local LAST NOW
    LAST=$(cat "$F" 2>/dev/null || echo 0)
    NOW=$(date +%s)
    (( NOW - LAST < $2 ))
}
_set_cd() {
    local F; F=$(_cd_file "$1")
    date +%s > "$F"
}
_cd_remaining() {
    local F; F=$(_cd_file "$1")
    [ -f "$F" ] || { echo 0; return; }
    local LAST NOW
    LAST=$(cat "$F" 2>/dev/null || echo 0)
    NOW=$(date +%s)
    echo $(( $2 - (NOW - LAST) ))
}

# ══════════════════════════════════════════════════════════════════════
# Lectura CPU sistema y por PID
# ══════════════════════════════════════════════════════════════════════
read_sys_stat() {
    awk '/^cpu / {idle=$5+$6; total=0; for(i=2;i<=NF;i++) total+=$i; print total, idle; exit}' /proc/stat
}

read_pid_ticks() {
    local PID="$1"
    [ -f "/proc/$PID/stat" ] || { echo 0; return; }
    awk '{print $14+$15+$16+$17}' /proc/$PID/stat 2>/dev/null || echo 0
}

# ══════════════════════════════════════════════════════════════════════
# Prescan T0 — snapshot de todos los PIDs no-safe
# ══════════════════════════════════════════════════════════════════════
declare -A ALL_TICKS_T0
declare -A ALL_COMM

prescan_t0() {
    ALL_TICKS_T0=()
    ALL_COMM=()
    for STATF in /proc/[0-9]*/stat; do
        local PID="${STATF%/stat}"; PID="${PID##*/}"
        [ "$PID" = "1" ] && continue
        local COMM
        COMM=$(cat /proc/$PID/comm 2>/dev/null || echo "")
        [ -z "$COMM" ] && continue
        if echo "$COMM" | grep -qE "$SAFE_PROCS_RE"; then continue; fi
        local TICKS
        TICKS=$(awk '{print $14+$15+$16+$17}' "$STATF" 2>/dev/null || echo 0)
        ALL_TICKS_T0[$PID]="$TICKS"
        ALL_COMM[$PID]="$COMM"
    done
}

# ══════════════════════════════════════════════════════════════════════
# identify_culprit()
#
# Orden de detección:
#   1. Servicios conocidos (xray, proxy, badvpn, stunnel)
#   2. Fallback individual (un proceso supera FALLBACK_CPU_MIN)
#   3. Detección grupal por nombre (suma de PIDs del mismo comm)
#   4. Selector de emergencia (mayor ticks sin umbral)
# ══════════════════════════════════════════════════════════════════════
identify_culprit() {
    CULPRIT="unknown"
    CULPRIT_CPU=0
    CULPRIT_MEM=0
    CULPRIT_GROUP_PIDS=""
    SYS_CPU_PCT=0

    local SYS_T0
    SYS_T0=$(read_sys_stat)
    local SYS_TOTAL_T0 SYS_IDLE_T0
    SYS_TOTAL_T0=$(echo "$SYS_T0" | awk '{print $1}')
    SYS_IDLE_T0=$(echo  "$SYS_T0" | awk '{print $2}')

    declare -A PID_TAG
    declare -A TAG_MEM_KB

    _add_known() {
        local TAG="$1"; shift
        for PID in "$@"; do
            [ -d "/proc/$PID" ] || continue
            PID_TAG[$PID]="$TAG"
            local MEM
            MEM=$(awk '/VmRSS/{print $2}' /proc/$PID/status 2>/dev/null || echo 0)
            TAG_MEM_KB[$TAG]=$(( MEM > ${TAG_MEM_KB[$TAG]:-0} ? MEM : ${TAG_MEM_KB[$TAG]:-0} ))
            ALL_TICKS_T0[$PID]=$(read_pid_ticks "$PID")
            ALL_COMM[$PID]="$TAG"
        done
    }

    prescan_t0

    _add_known "xray"    $(pgrep -x xray 2>/dev/null)
    _add_known "proxy"   $(pgrep -f "$PROXY_SCRIPT" 2>/dev/null)
    _add_known "badvpn"  $(pgrep -x badvpn-udpgw 2>/dev/null)
    _add_known "stunnel" $(pgrep -x stunnel4 2>/dev/null; pgrep -x stunnel 2>/dev/null)

    sleep "$SAMPLE_INTERVAL"

    local SYS_T1
    SYS_T1=$(read_sys_stat)
    local SYS_TOTAL_T1 SYS_IDLE_T1
    SYS_TOTAL_T1=$(echo "$SYS_T1" | awk '{print $1}')
    SYS_IDLE_T1=$(echo  "$SYS_T1" | awk '{print $2}')
    local DELTA_SYS=$(( SYS_TOTAL_T1 - SYS_TOTAL_T0 ))
    local DELTA_IDLE=$(( SYS_IDLE_T1 - SYS_IDLE_T0 ))

    if [ "$DELTA_SYS" -le 0 ]; then
        log "SCAN: delta sistema = 0 — tick muy corto"
        return
    fi

    SYS_CPU_PCT=$(awk "BEGIN {printf \"%.0f\", (($DELTA_SYS-$DELTA_IDLE)/$DELTA_SYS)*100}")
    local TOTAL_RAM_KB
    TOTAL_RAM_KB=$(awk '/MemTotal/{print $2}' /proc/meminfo)

    # ── Calcular delta de ticks para todos los PIDs ───────────────────
    declare -A PID_DELTA
    declare -A PID_CPU_PCT

    for PID in "${!ALL_TICKS_T0[@]}"; do
        [ -f "/proc/$PID/stat" ] || continue
        local T1
        T1=$(read_pid_ticks "$PID")
        local DELTA=$(( T1 - ALL_TICKS_T0[$PID] ))
        [ "$DELTA" -lt 0 ] && DELTA=0
        PID_DELTA[$PID]="$DELTA"
        PID_CPU_PCT[$PID]=$(awk "BEGIN {printf \"%.0f\", ($DELTA/$DELTA_SYS)*100}")
    done

    # ── Top N para log y fallback individual ─────────────────────────
    TOP_PIDS_SORTED=$(for PID in "${!PID_DELTA[@]}"; do
        echo "${PID_DELTA[$PID]} $PID"
    done | sort -rn | head -"$TOP_N_PROCS" | awk '{print $2}')

    declare -A TAG_CPU_REAL
    local SCAN_LOG="SCAN sys_cpu=${SYS_CPU_PCT}%:"

    # ── CAPAS 1 y 2: Servicios conocidos + fallback individual ────────
    for PID in $TOP_PIDS_SORTED; do
        local TAG="${PID_TAG[$PID]:-}"
        local COMM="${ALL_COMM[$PID]:-unknown}"
        local PID_CPU="${PID_CPU_PCT[$PID]:-0}"
        local VmRSS
        VmRSS=$(awk '/VmRSS/{print $2}' /proc/$PID/status 2>/dev/null || echo 0)
        local PID_MEM
        PID_MEM=$(awk "BEGIN {printf \"%.0f\", ($VmRSS/${TOTAL_RAM_KB:-1})*100}")

        if [ -n "$TAG" ]; then
            # CAPA 1: servicio conocido
            TAG_CPU_REAL[$TAG]=$(( ${TAG_CPU_REAL[$TAG]:-0} + PID_CPU ))
            TAG_MEM_KB[$TAG]=$(( VmRSS > ${TAG_MEM_KB[$TAG]:-0} ? VmRSS : ${TAG_MEM_KB[$TAG]:-0} ))
            SCAN_LOG="${SCAN_LOG} ${TAG}=${PID_CPU}%cpu/${PID_MEM}%mem"

            if [ "${TAG_CPU_REAL[$TAG]}" -gt "$CULPRIT_CPU" ]; then
                CULPRIT="$TAG"
                CULPRIT_CPU="${TAG_CPU_REAL[$TAG]}"
                CULPRIT_MEM=$(awk "BEGIN {printf \"%.0f\", (${TAG_MEM_KB[$TAG]}/${TOTAL_RAM_KB:-1})*100}")
            fi
        else
            SCAN_LOG="${SCAN_LOG} ${COMM}[${PID}]=${PID_CPU}%cpu/${PID_MEM}%mem"

            # CAPA 2: fallback individual
            if [ "$PID_CPU" -ge "$FALLBACK_CPU_MIN" ]; then
                local FB_CPU_CTR_F="${FB_CPU_DIR}/pid_${PID}"
                local FB_CPU_CTR
                FB_CPU_CTR=$(cat "$FB_CPU_CTR_F" 2>/dev/null || echo 0)
                FB_CPU_CTR=$(( FB_CPU_CTR + 1 ))
                echo "$FB_CPU_CTR" > "$FB_CPU_CTR_F"
                log "FALLBACK-CPU: ${COMM} (PID $PID) = ${PID_CPU}%cpu — ciclo ${FB_CPU_CTR}/${FALLBACK_CPU_CYCLES}"

                if [ "$FB_CPU_CTR" -ge "$FALLBACK_CPU_CYCLES" ]; then
                    if [ "$PID_CPU" -gt "$CULPRIT_CPU" ] || [ "$CULPRIT" = "unknown" ]; then
                        CULPRIT="fallback_cpu:${COMM}:${PID}"
                        CULPRIT_CPU="$PID_CPU"
                        CULPRIT_MEM="$PID_MEM"
                    fi
                fi
            else
                local FB_CPU_CTR_F="${FB_CPU_DIR}/pid_${PID}"
                if [ -f "$FB_CPU_CTR_F" ]; then
                    local CUR; CUR=$(cat "$FB_CPU_CTR_F" 2>/dev/null || echo 0)
                    [ "$CUR" -gt 0 ] && echo $(( CUR - 1 )) > "$FB_CPU_CTR_F" || rm -f "$FB_CPU_CTR_F"
                fi
            fi

            # Fallback RAM
            if [ "$PID_MEM" -ge "$FALLBACK_RAM_MIN" ]; then
                local FB_RAM_CTR_F="${FB_RAM_DIR}/pid_${PID}"
                local FB_RAM_CTR
                FB_RAM_CTR=$(cat "$FB_RAM_CTR_F" 2>/dev/null || echo 0)
                FB_RAM_CTR=$(( FB_RAM_CTR + 1 ))
                echo "$FB_RAM_CTR" > "$FB_RAM_CTR_F"
                log "FALLBACK-RAM: ${COMM} (PID $PID) = ${PID_MEM}%mem — ciclo ${FB_RAM_CTR}/${FALLBACK_RAM_CYCLES}"

                if [ "$FB_RAM_CTR" -ge "$FALLBACK_RAM_CYCLES" ] && [ "$CULPRIT" = "unknown" ]; then
                    CULPRIT="fallback_ram:${COMM}:${PID}"
                    CULPRIT_CPU="$PID_CPU"
                    CULPRIT_MEM="$PID_MEM"
                fi
            else
                local FB_RAM_CTR_F="${FB_RAM_DIR}/pid_${PID}"
                if [ -f "$FB_RAM_CTR_F" ]; then
                    local CUR; CUR=$(cat "$FB_RAM_CTR_F" 2>/dev/null || echo 0)
                    [ "$CUR" -gt 0 ] && echo $(( CUR - 1 )) > "$FB_RAM_CTR_F" || rm -f "$FB_RAM_CTR_F"
                fi
            fi
        fi
    done

    log "$SCAN_LOG"

    # ══════════════════════════════════════════════════════════════════
    # CAPA 3: Detección grupal por nombre (NUEVO v4.6)
    #
    # Recorre TODOS los PIDs no-safe (no solo top N), suma su CPU
    # por nombre de proceso. Si un grupo supera GROUP_CPU_MIN por
    # GROUP_CPU_CYCLES ciclos, se convierte en culprit.
    #
    # Cubre exactamente el caso: N procesos pequeños del mismo nombre
    # que individualmente no superan ningún umbral pero en suma saturan.
    # ══════════════════════════════════════════════════════════════════
    declare -A COMM_CPU_SUM   # CPU agregada por nombre
    declare -A COMM_PIDS_ALL  # PIDs por nombre (string separado por espacios)

    for PID in "${!PID_DELTA[@]}"; do
        [ -n "${PID_TAG[$PID]:-}" ] && continue   # servicio conocido, skip
        local COMM="${ALL_COMM[$PID]:-}"
        [ -z "$COMM" ] && continue
        local PCPU="${PID_CPU_PCT[$PID]:-0}"
        [ "$PCPU" -eq 0 ] && continue
        COMM_CPU_SUM[$COMM]=$(( ${COMM_CPU_SUM[$COMM]:-0} + PCPU ))
        COMM_PIDS_ALL[$COMM]="${COMM_PIDS_ALL[$COMM]:-}${PID} "
    done

    # Encontrar el grupo con mayor CPU agregada
    local BEST_GROUP="" BEST_GROUP_CPU=0 BEST_GROUP_PIDS=""
    for COMM in "${!COMM_CPU_SUM[@]}"; do
        local GCPU="${COMM_CPU_SUM[$COMM]}"
        if [ "$GCPU" -gt "$BEST_GROUP_CPU" ]; then
            BEST_GROUP_CPU="$GCPU"
            BEST_GROUP="$COMM"
            BEST_GROUP_PIDS="${COMM_PIDS_ALL[$COMM]}"
        fi
    done

    if [ -n "$BEST_GROUP" ] && [ "$BEST_GROUP_CPU" -ge "$GROUP_CPU_MIN" ]; then
        local GRP_CTR_F="${GRP_DIR}/${BEST_GROUP}"
        local GRP_CTR
        GRP_CTR=$(cat "$GRP_CTR_F" 2>/dev/null || echo 0)
        GRP_CTR=$(( GRP_CTR + 1 ))
        echo "$GRP_CTR" > "$GRP_CTR_F"

        local NPIDS
        NPIDS=$(echo "$BEST_GROUP_PIDS" | wc -w)
        log "GROUP: ${BEST_GROUP} = ${BEST_GROUP_CPU}%cpu (${NPIDS} PIDs) — ciclo ${GRP_CTR}/${GROUP_CPU_CYCLES}"

        if [ "$GRP_CTR" -ge "$GROUP_CPU_CYCLES" ]; then
            # El grupo gana si tiene más CPU que el culprit actual
            # o si no hay culprit identificado todavía.
            if [ "$BEST_GROUP_CPU" -gt "$CULPRIT_CPU" ] || [ "$CULPRIT" = "unknown" ]; then
                CULPRIT="group:${BEST_GROUP}"
                CULPRIT_CPU="$BEST_GROUP_CPU"
                CULPRIT_GROUP_PIDS="$BEST_GROUP_PIDS"
                log "GROUP: culprit → group:${BEST_GROUP} (${BEST_GROUP_CPU}%cpu, ${NPIDS} PIDs: ${BEST_GROUP_PIDS})"
            fi
        fi
    fi

    # Decrementar contadores de grupos que bajaron bajo el umbral
    for F in "${GRP_DIR}"/*; do
        [ -f "$F" ] || continue
        local GNAME="${F##*/}"
        local GCPU="${COMM_CPU_SUM[$GNAME]:-0}"
        if [ "$GCPU" -lt "$GROUP_CPU_MIN" ]; then
            local CUR; CUR=$(cat "$F" 2>/dev/null || echo 0)
            if [ "$CUR" -gt 0 ]; then
                echo $(( CUR - 1 )) > "$F"
            else
                rm -f "$F"
            fi
        fi
    done

    # ══════════════════════════════════════════════════════════════════
    # CAPA 4: Selector de emergencia
    #
    # Último recurso: si culprit sigue unknown con CPU >= CPU_WARN,
    # toma el proceso no-safe con más ticks del período y lo acumula.
    # Sin importar si supera algún umbral individual.
    # Garantía dura: VPS al 96% → siempre habrá alguna acción.
    # ══════════════════════════════════════════════════════════════════
    if [ "$CULPRIT" = "unknown" ] && [ "$SYS_CPU_PCT" -ge "$CPU_WARN" ]; then
        local BEST_PID="" BEST_DELTA=0
        for PID in $TOP_PIDS_SORTED; do
            [ -n "${PID_TAG[$PID]:-}" ] && continue
            local D="${PID_DELTA[$PID]:-0}"
            if [ "$D" -gt "$BEST_DELTA" ]; then
                BEST_DELTA="$D"
                BEST_PID="$PID"
            fi
        done

        if [ -n "$BEST_PID" ]; then
            local B_COMM="${ALL_COMM[$BEST_PID]:-unknown}"
            local B_CPU="${PID_CPU_PCT[$BEST_PID]:-0}"
            local B_VmRSS
            B_VmRSS=$(awk '/VmRSS/{print $2}' /proc/$BEST_PID/status 2>/dev/null || echo 0)
            local B_MEM
            B_MEM=$(awk "BEGIN {printf \"%.0f\", ($B_VmRSS/${TOTAL_RAM_KB:-1})*100}")

            local EM_CTR_F="${FB_CPU_DIR}/pid_${BEST_PID}"
            local EM_CTR
            EM_CTR=$(cat "$EM_CTR_F" 2>/dev/null || echo 0)
            EM_CTR=$(( EM_CTR + 1 ))
            echo "$EM_CTR" > "$EM_CTR_F"

            log "EMERGENCY: top no-safe → ${B_COMM} [PID ${BEST_PID}] = ${B_CPU}%cpu — ciclo ${EM_CTR}/${FALLBACK_CPU_CYCLES}"

            if [ "$EM_CTR" -ge "$FALLBACK_CPU_CYCLES" ]; then
                CULPRIT="fallback_cpu:${B_COMM}:${BEST_PID}"
                CULPRIT_CPU="$B_CPU"
                CULPRIT_MEM="$B_MEM"
                log "EMERGENCY: culprit forzado → ${CULPRIT}"
            fi
        else
            log "EMERGENCY: no se encontró proceso candidato (todos son safe o conocidos)"
        fi
    fi

    log "RESULT: culprit=${CULPRIT} (cpu=${CULPRIT_CPU}% mem=${CULPRIT_MEM}%) sys_cpu=${SYS_CPU_PCT}%"

    # ── Limpiar contadores huérfanos ──────────────────────────────────
    for F in "${FB_CPU_DIR}"/pid_* "${FB_RAM_DIR}"/pid_*; do
        [ -f "$F" ] || continue
        local FPID="${F##*pid_}"
        [ -d "/proc/$FPID" ] || rm -f "$F"
    done
}

# ══════════════════════════════════════════════════════════════════════
# Acciones por servicio conocido
