read_sys_stat() {
    awk '/^cpu / {idle=$5+$6; total=0; for(i=2;i<=NF;i++) total+=$i; print total, idle; exit}' /proc/stat
}

read_pid_ticks() {
    local PID="$1"
    [ -f "/proc/$PID/stat" ] || { echo 0; return; }
    awk '{print $14+$15+$16+$17}' /proc/$PID/stat 2>/dev/null || echo 0
}

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# Prescan T0 вЂ” snapshot de todos los PIDs
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
declare -A ALL_TICKS_T0
declare -A ALL_COMM

prescan_t0() {
    ALL_TICKS_T0=()
    ALL_COMM=()
    for STATF in /proc/[0-9]*/stat; do
        local PID="${STATF%/stat}"; PID="${PID##*/}"
        [ "$PID" = "1" ] && continue
        local COMM
        COMM=$(cat /proc/$PID/comm 2>/dev/null || echo "")
        [ -z "$COMM" ] && continue
        if echo "$COMM" | grep -qE "$SAFE_PROCS_RE"; then continue; fi
        local TICKS
        TICKS=$(awk '{print $14+$15+$16+$17}' "$STATF" 2>/dev/null || echo 0)
        ALL_TICKS_T0[$PID]="$TICKS"
        ALL_COMM[$PID]="$COMM"
    done
}

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# identify_culprit()
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
identify_culprit() {
    CULPRIT="unknown"
    CULPRIT_CPU=0
    CULPRIT_MEM=0
    SYS_CPU_PCT=0

    local SYS_T0
    SYS_T0=$(read_sys_stat)
    local SYS_TOTAL_T0 SYS_IDLE_T0
    SYS_TOTAL_T0=$(echo "$SYS_T0" | awk '{print $1}')
    SYS_IDLE_T0=$(echo  "$SYS_T0" | awk '{print $2}')

    declare -A PID_TAG
    declare -A TAG_MEM_KB

    _add_known() {
        local TAG="$1"; shift
        for PID in "$@"; do
            [ -d "/proc/$PID" ] || continue
            PID_TAG[$PID]="$TAG"
            local MEM
            MEM=$(awk '/VmRSS/{print $2}' /proc/$PID/status 2>/dev/null || echo 0)
            TAG_MEM_KB[$TAG]=$(( MEM > ${TAG_MEM_KB[$TAG]:-0} ? MEM : ${TAG_MEM_KB[$TAG]:-0} ))
            ALL_TICKS_T0[$PID]=$(read_pid_ticks "$PID")
            ALL_COMM[$PID]="$TAG"
        done
    }

    prescan_t0

    _add_known "xray"    $(pgrep -x xray 2>/dev/null)
    _add_known "proxy"   $(pgrep -f "$PROXY_SCRIPT" 2>/dev/null)
    _add_known "badvpn"  $(pgrep -x badvpn-udpgw 2>/dev/null)
    _add_known "stunnel" $(pgrep -x stunnel4 2>/dev/null; pgrep -x stunnel 2>/dev/null)

    sleep "$SAMPLE_INTERVAL"

    local SYS_T1
    SYS_T1=$(read_sys_stat)
    local SYS_TOTAL_T1 SYS_IDLE_T1
    SYS_TOTAL_T1=$(echo "$SYS_T1" | awk '{print $1}')
    SYS_IDLE_T1=$(echo  "$SYS_T1" | awk '{print $2}')
    local DELTA_SYS=$(( SYS_TOTAL_T1 - SYS_TOTAL_T0 ))
    local DELTA_IDLE=$(( SYS_IDLE_T1 - SYS_IDLE_T0 ))

    if [ "$DELTA_SYS" -le 0 ]; then
        log "SCAN: delta sistema = 0 вЂ” tick muy corto"
        return
    fi

    SYS_CPU_PCT=$(awk "BEGIN {printf \"%.0f\", (($DELTA_SYS-$DELTA_IDLE)/$DELTA_SYS)*100}")
    local TOTAL_RAM_KB
    TOTAL_RAM_KB=$(awk '/MemTotal/{print $2}' /proc/meminfo)

    declare -A PID_DELTA
    for PID in "${!ALL_TICKS_T0[@]}"; do
        [ -f "/proc/$PID/stat" ] || continue
        local T1
        T1=$(read_pid_ticks "$PID")
        local DELTA=$(( T1 - ALL_TICKS_T0[$PID] ))
        [ "$DELTA" -lt 0 ] && DELTA=0
        PID_DELTA[$PID]="$DELTA"
    done

    TOP_PIDS_SORTED=$(for PID in "${!PID_DELTA[@]}"; do
        echo "${PID_DELTA[$PID]} $PID"
    done | sort -rn | head -"$TOP_N_PROCS" | awk '{print $2}')

    declare -A TAG_CPU_REAL
    local SCAN_LOG="SCAN sys_cpu=${SYS_CPU_PCT}%:"

    for PID in $TOP_PIDS_SORTED; do
        local TAG="${PID_TAG[$PID]:-}"
        local COMM="${ALL_COMM[$PID]:-unknown}"
        local DELTA="${PID_DELTA[$PID]:-0}"
        local PID_CPU
        PID_CPU=$(awk "BEGIN {printf \"%.0f\", ($DELTA/$DELTA_SYS)*100}")
        local VmRSS
        VmRSS=$(awk '/VmRSS/{print $2}' /proc/$PID/status 2>/dev/null || echo 0)
        local PID_MEM
        PID_MEM=$(awk "BEGIN {printf \"%.0f\", ($VmRSS/${TOTAL_RAM_KB:-1})*100}")

        if [ -n "$TAG" ]; then
            TAG_CPU_REAL[$TAG]=$(( ${TAG_CPU_REAL[$TAG]:-0} + PID_CPU ))
            TAG_MEM_KB[$TAG]=$(( VmRSS > ${TAG_MEM_KB[$TAG]:-0} ? VmRSS : ${TAG_MEM_KB[$TAG]:-0} ))
            SCAN_LOG="${SCAN_LOG} ${TAG}=${PID_CPU}%cpu/${PID_MEM}%mem"

            if [ "${TAG_CPU_REAL[$TAG]}" -gt "$CULPRIT_CPU" ]; then
                CULPRIT="$TAG"
                CULPRIT_CPU="${TAG_CPU_REAL[$TAG]}"
                CULPRIT_MEM=$(awk "BEGIN {printf \"%.0f\", (${TAG_MEM_KB[$TAG]}/${TOTAL_RAM_KB:-1})*100}")
            fi
        else
            SCAN_LOG="${SCAN_LOG} ${COMM}[${PID}]=${PID_CPU}%cpu/${PID_MEM}%mem"

            # в”Ђв”Ђ Fallback CPU в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
            if [ "$PID_CPU" -ge "$FALLBACK_CPU_MIN" ]; then
                local FB_CPU_CTR_F="${FB_CPU_DIR}/pid_${PID}"
                local FB_CPU_CTR
                FB_CPU_CTR=$(cat "$FB_CPU_CTR_F" 2>/dev/null || echo 0)
                FB_CPU_CTR=$(( FB_CPU_CTR + 1 ))
                echo "$FB_CPU_CTR" > "$FB_CPU_CTR_F"
                log "FALLBACK-CPU: ${COMM} (PID $PID) = ${PID_CPU}%cpu вЂ” ciclo ${FB_CPU_CTR}/${FALLBACK_CPU_CYCLES}"

                if [ "$FB_CPU_CTR" -ge "$FALLBACK_CPU_CYCLES" ] && [ "$PID_CPU" -gt "$CULPRIT_CPU" ]; then
                    CULPRIT="fallback_cpu:${COMM}:${PID}"
                    CULPRIT_CPU="$PID_CPU"
                    CULPRIT_MEM="$PID_MEM"
                fi
            else
                local FB_CPU_CTR_F="${FB_CPU_DIR}/pid_${PID}"
                if [ -f "$FB_CPU_CTR_F" ]; then
                    local CUR; CUR=$(cat "$FB_CPU_CTR_F" 2>/dev/null || echo 0)
                    if [ "$CUR" -gt 0 ]; then
                        echo $(( CUR - 1 )) > "$FB_CPU_CTR_F"
                    else
                        rm -f "$FB_CPU_CTR_F"
                    fi
                fi
            fi

            # в”Ђв”Ђ Fallback RAM в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
            if [ "$PID_MEM" -ge "$FALLBACK_RAM_MIN" ]; then
                local FB_RAM_CTR_F="${FB_RAM_DIR}/pid_${PID}"
                local FB_RAM_CTR
                FB_RAM_CTR=$(cat "$FB_RAM_CTR_F" 2>/dev/null || echo 0)
                FB_RAM_CTR=$(( FB_RAM_CTR + 1 ))
                echo "$FB_RAM_CTR" > "$FB_RAM_CTR_F"
                log "FALLBACK-RAM: ${COMM} (PID $PID) = ${PID_MEM}%mem вЂ” ciclo ${FB_RAM_CTR}/${FALLBACK_RAM_CYCLES}"

                if [ "$FB_RAM_CTR" -ge "$FALLBACK_RAM_CYCLES" ] && [ "$CULPRIT" = "unknown" ]; then
                    CULPRIT="fallback_ram:${COMM}:${PID}"
                    CULPRIT_CPU="$PID_CPU"
                    CULPRIT_MEM="$PID_MEM"
                fi
            else
                local FB_RAM_CTR_F="${FB_RAM_DIR}/pid_${PID}"
                if [ -f "$FB_RAM_CTR_F" ]; then
                    local CUR; CUR=$(cat "$FB_RAM_CTR_F" 2>/dev/null || echo 0)
                    if [ "$CUR" -gt 0 ]; then
                        echo $(( CUR - 1 )) > "$FB_RAM_CTR_F"
                    else
                        rm -f "$FB_RAM_CTR_F"
                    fi
                fi
            fi
        fi
    done

    log "$SCAN_LOG"
    log "RESULT: culprit=${CULPRIT} (cpu=${CULPRIT_CPU}% mem=${CULPRIT_MEM}%) sys_cpu=${SYS_CPU_PCT}%"

    # Limpiar contadores huГ©rfanos
    for F in "${FB_CPU_DIR}"/pid_* "${FB_RAM_DIR}"/pid_*; do
        [ -f "$F" ] || continue
        local FPID="${F##*pid_}"
        [ -d "/proc/$FPID" ] || rm -f "$F"
    done
}

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# Acciones por servicio conocido
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
do_restart_xray() {
    log "ACTION [xray]: x-ui restart-xray"
    x-ui restart-xray >> "$LOG" 2>&1
    local EC=$?
    [ "$EC" -eq 0 ] && log "OK [xray]: reiniciado" || log "ERROR [xray]: fallo (exit $EC)"
    _set_cd "xray"
}

do_restart_proxy() {
    log "ACTION [proxy]: reiniciando PDirect.py"
    pkill -f "$PROXY_SCRIPT" 2>/dev/null; sleep 2
    nohup python3 "$PROXY_SCRIPT" "$PROXY_PORT" > /root/nohup.out 2>&1 &
    sleep 2
    pgrep -f "$PROXY_SCRIPT" > /dev/null \
        && log "OK [proxy]: PDirect.py reiniciado (PID $(pgrep -f "$PROXY_SCRIPT" | head -1))" \
        || log "ERROR [proxy]: no arrancГі"
    _set_cd "proxy"
}

do_restart_badvpn() {
    log "ACTION [badvpn]: reiniciando instancias 7200 y 7300"
    pkill -f "badvpn-udpgw" 2>/dev/null
    screen -S badvpn   -X quit 2>/dev/null
    screen -S badUDP72 -X quit 2>/dev/null
    sleep 2
    screen -dmS badvpn   /usr/bin/badvpn-udpgw --listen-addr 127.0.0.1:7300 \
        --max-clients 1000 --max-connections-for-client 10
    screen -dmS badUDP72 /usr/bin/badvpn-udpgw --listen-addr 127.0.0.1:7200 \
        --max-clients 1000 --max-connections-for-client 10
    sleep 2
    pgrep -f "badvpn-udpgw" > /dev/null \
        && log "OK [badvpn]: instancias reiniciadas" \
        || log "ERROR [badvpn]: no arrancГі"
    _set_cd "badvpn"
}

do_restart_stunnel() {
    log "ACTION [stunnel]: systemctl restart stunnel4"
    systemctl restart stunnel4 >> "$LOG" 2>&1
    local EC=$?
    [ "$EC" -eq 0 ] && log "OK [stunnel]: reiniciado" || log "ERROR [stunnel]: fallo (exit $EC)"
    _set_cd "stunnel"
}

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# AcciГіn escalonada fallback: SIGTERM в†’ SIGKILL
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
do_kill_fallback() {
    local TYPE="$1"
    local FB_NAME="$2"
    local FB_PID="$3"
    local CTR_DIR
    [ "$TYPE" = "cpu" ] && CTR_DIR="$FB_CPU_DIR" || CTR_DIR="$FB_RAM_DIR"
    local FB_CTR_F="${CTR_DIR}/pid_${FB_PID}"
    local FB_CTR
    FB_CTR=$(cat "$FB_CTR_F" 2>/dev/null || echo 0)

    if ! kill -0 "$FB_PID" 2>/dev/null; then
        log "FALLBACK-${TYPE^^}: PID $FB_PID ($FB_NAME) ya no existe"
        rm -f "$FB_CTR_F"; _set_cd "fallback_${TYPE}_${FB_PID}"
        return
    fi

    # Primer ciclo de acciГіn в†’ SIGTERM
    if [ "$FB_CTR" -eq "$( [ "$TYPE" = "cpu" ] && echo $FALLBACK_CPU_CYCLES || echo $FALLBACK_RAM_CYCLES )" ]; then
        log "ACTION [fallback-${TYPE}]: SIGTERM в†’ $FB_NAME (PID $FB_PID)"
        kill -15 "$FB_PID" 2>/dev/null
        echo $(( FB_CTR + 1 )) > "$FB_CTR_F"
        log "INFO: esperando prГіximo ciclo para verificar si terminГі"
        return
    fi

    # Ciclos siguientes в†’ SIGKILL si sobreviviГі
    if kill -0 "$FB_PID" 2>/dev/null; then
        log "ACTION [fallback-${TYPE}]: SIGKILL в†’ $FB_NAME (PID $FB_PID) [ignorГі SIGTERM]"
        kill -9 "$FB_PID" 2>/dev/null
        sleep 1
        kill -0 "$FB_PID" 2>/dev/null \
            && log "ERROR [fallback-${TYPE}]: PID $FB_PID no respondiГі a SIGKILL вЂ” posible hilo kernel" \
            || { log "OK [fallback-${TYPE}]: $FB_NAME terminado con SIGKILL"; rm -f "$FB_CTR_F"; }
    else
        log "OK [fallback-${TYPE}]: $FB_NAME (PID $FB_PID) terminГі con SIGTERM"
        rm -f "$FB_CTR_F"
    fi
    _set_cd "fallback_${TYPE}_${FB_PID}"
}

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# dispatch_action() вЂ” verifica cooldown y despacha
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
dispatch_action() {
    local REASON="$1"
    log "TRIGGER: $REASON в†’ culprit=${CULPRIT}"

    case "$CULPRIT" in
        xray)
            _in_cd "xray" "$COOLDOWN_KNOWN" \
                && { log "CD [xray]: en cooldown ($(_cd_remaining xray $COOLDOWN_KNOWN)s restantes)"; return; }
            do_restart_xray ;;
        proxy)
            _in_cd "proxy" "$COOLDOWN_KNOWN" \
                && { log "CD [proxy]: en cooldown"; return; }
            do_restart_proxy ;;
        badvpn)
            _in_cd "badvpn" "$COOLDOWN_KNOWN" \
                && { log "CD [badvpn]: en cooldown"; return; }
            do_restart_badvpn ;;
        stunnel)
            _in_cd "stunnel" "$COOLDOWN_KNOWN" \
                && { log "CD [stunnel]: en cooldown"; return; }
            do_restart_stunnel ;;
        fallback_cpu:*)
            local FB_NAME; FB_NAME=$(echo "$CULPRIT" | cut -d: -f2)
            local FB_PID;  FB_PID=$(echo  "$CULPRIT" | cut -d: -f3)
            local CD_KEY="fallback_cpu_${FB_PID}"
            _in_cd "$CD_KEY" "$COOLDOWN_FALLBACK" \
                && { log "CD [fallback-cpu]: $FB_NAME en cooldown"; return; }
            do_kill_fallback "cpu" "$FB_NAME" "$FB_PID" ;;
        fallback_ram:*)
            local FB_NAME; FB_NAME=$(echo "$CULPRIT" | cut -d: -f2)
            local FB_PID;  FB_PID=$(echo  "$CULPRIT" | cut -d: -f3)
            local CD_KEY="fallback_ram_${FB_PID}"
            _in_cd "$CD_KEY" "$COOLDOWN_FALLBACK" \
                && { log "CD [fallback-ram]: $FB_NAME en cooldown"; return; }
            do_kill_fallback "ram" "$FB_NAME" "$FB_PID" ;;
        unknown)
            log "WARN: culprit=unknown вЂ” sin proceso identificable вЂ” SIN ACCIГ“N (falla segura)"
            return ;;
    esac
}

