cat > /usr/local/sbin/clean-vps.sh << 'CLEANEOF'
#!/bin/bash
# =============================================================================
# clean-vps.sh — Limpieza directa para VPS personal
# v2.1 — Sin backups, sin historia, el camión se lleva todo
# =============================================================================

LOG="/var/log/clean-vps.log"
LOCK="/tmp/clean-vps.lock"
DRY_RUN=false
ERRORS=0

for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=true ;;
    --help)
      echo "Uso: $0 [--dry-run]"
      echo "  --dry-run   Muestra qué haría sin ejecutar nada"
      exit 0 ;;
  esac
done

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG"; }
run() {
  if $DRY_RUN; then log "[DRY-RUN] $*"
  else eval "$@" >> "$LOG" 2>&1 || { log "⚠️  Falló: $*"; ((ERRORS++)); }
  fi
}

[[ $EUID -ne 0 ]] && { echo "❌ Ejecutá como root: sudo $0"; exit 1; }

exec 9>"$LOCK"
flock -n 9 || { log "⚠️  Ya hay una instancia corriendo."; exit 1; }

echo "" >> "$LOG"; echo "=== $(date) ===" >> "$LOG"
$DRY_RUN && log "👁️  Modo DRY-RUN activo"
log "🚀 Iniciando limpieza..."

ESPACIO_ANTES=$(df / | awk 'NR==2{print $3}')

log "🧹 APT autoremove + clean..."
run "apt-get autoremove -y"; run "apt-get clean"

log "🧠 Eliminando kernels viejos..."
CURRENT=$(uname -r)
OLD_KERNELS=$(dpkg -l 'linux-image-*' | awk '/^ii/{print $2}' | grep -v "$CURRENT" | sort -V | head -n -2)
if [[ -n "$OLD_KERNELS" ]]; then
  run "echo '$OLD_KERNELS' | xargs --no-run-if-empty apt-get purge -y"
else
  log "✔️  Sin kernels viejos"
fi

log "📊 Journald → 100MB..."
run "journalctl --rotate"; run "journalctl --vacuum-size=100M"

log "🗑️  Borrando logs rotados (+7 días)..."
if $DRY_RUN; then
  find /var/log -maxdepth 1 -type f \( -name "*.gz" -o -name "*.old" -o -name "*.[0-9]" \) \
    -mtime +7 | while read f; do log "[DRY-RUN] Borraría: $f"; done
else
  find /var/log -maxdepth 1 -type f \( -name "*.gz" -o -name "*.old" -o -name "*.[0-9]" \) \
    -mtime +7 -delete >> "$LOG" 2>&1
fi

log "💣 Truncando logs grandes (+50MB)..."
find /var/log -type f -size +50M | while read f; do
  [[ "$f" == "$LOG" ]] && continue
  SIZE_MB=$(du -m "$f" 2>/dev/null | cut -f1)
  if $DRY_RUN; then log "[DRY-RUN] Truncaría: $f (${SIZE_MB}MB)"
  else truncate -s 0 "$f"; log "💣 Truncado: $f (${SIZE_MB}MB)"; fi
done

log "🧹 Cache root (+30 días)..."
$DRY_RUN \
  && find /root/.cache -type f -mtime +30 | wc -l | COUNT=$(find /root/.cache -type f -mtime +30 | wc -l)
log "[DRY-RUN] $COUNT archivos en /root/.cache" \
  || find /root/.cache -type f -mtime +30 -delete 2>/dev/null

log "🧹 /tmp (+7 días)..."
$DRY_RUN \
  && find /tmp -type f -mtime +7 | wc -l | xargs -I{} log "[DRY-RUN] {} archivos en /tmp" \
  || find /tmp -type f -mtime +7 -delete 2>/dev/null

if command -v snap &>/dev/null; then
  log "📦 Limpiando snaps viejos..."
  snap list --all 2>/dev/null | awk '/disabled/{print $1, $3}' | while read snapname revision; do
    $DRY_RUN \
      && log "[DRY-RUN] Removería snap: $snapname rev.$revision" \
      || run "snap remove '$snapname' --revision='$revision'"
  done
else
  log "⏭️  Snap no instalado, saltando..."
fi

if ! $DRY_RUN; then
  cat > /etc/logrotate.d/clean-vps <<LREOF
/var/log/clean-vps.log { weekly; rotate 4; compress; missingok; notifempty }
LREOF
  log "📄 Logrotate OK"
fi

ESPACIO_DESPUES=$(df / | awk 'NR==2{print $3}')
LIBERADO_MB=$(( (ESPACIO_ANTES - ESPACIO_DESPUES) / 1024 ))
LIBRE=$(df -h / | awk 'NR==2{print $4}')
echo "" >> "$LOG"
log "─────────────────────────────────────────"
$DRY_RUN \
  && log "👁️  DRY-RUN finalizado — no se tocó nada" \
  || { log "📉 Liberado: ${LIBERADO_MB}MB  |  Libre en /: $LIBRE"
       [[ $ERRORS -gt 0 ]] && log "⚠️  $ERRORS error(es)" || log "✅ Limpieza sin errores"; }
log "─────────────────────────────────────────"
echo "" >> "$LOG"
CLEANEOF

chmod +x /usr/local/sbin/clean-vps.sh

CRON_JOB="0 3 * * * /usr/local/sbin/clean-vps.sh"
CRON_TMP=$(mktemp)
crontab -l 2>/dev/null > "$CRON_TMP" || true
if ! grep -qF "clean-vps.sh" "$CRON_TMP"; then
  echo "$CRON_JOB" >> "$CRON_TMP"
  crontab "$CRON_TMP" && echo "⏰ Cron clean-vps registrado: $CRON_JOB"
fi
rm -f "$CRON_TMP"
echo "✅ clean-vps instalado y cron activo (3am diario)"
