do_restart_xray() {
    log "ACTION [xray]: x-ui restart-xray"
    x-ui restart-xray >> "$LOG" 2>&1
    local EC=$?
    [ "$EC" -eq 0 ] && log "OK [xray]: reiniciado" || log "ERROR [xray]: fallo (exit $EC)"
    _set_cd "xray"
}

do_restart_proxy() {
    log "ACTION [proxy]: reiniciando PDirect.py"
    pkill -f "$PROXY_SCRIPT" 2>/dev/null; sleep 2
    nohup python3 "$PROXY_SCRIPT" "$PROXY_PORT" > /root/nohup.out 2>&1 &
    sleep 2
    pgrep -f "$PROXY_SCRIPT" > /dev/null \
        && log "OK [proxy]: PDirect.py reiniciado (PID $(pgrep -f "$PROXY_SCRIPT" | head -1))" \
        || log "ERROR [proxy]: no arrancó"
    _set_cd "proxy"
}

do_restart_badvpn() {
    log "ACTION [badvpn]: reiniciando instancias 7200 y 7300"
    pkill -f "badvpn-udpgw" 2>/dev/null
    screen -S badvpn   -X quit 2>/dev/null
    screen -S badUDP72 -X quit 2>/dev/null
    sleep 2
    screen -dmS badvpn   /usr/bin/badvpn-udpgw --listen-addr 127.0.0.1:7300 \
        --max-clients 1000 --max-connections-for-client 10
    screen -dmS badUDP72 /usr/bin/badvpn-udpgw --listen-addr 127.0.0.1:7200 \
        --max-clients 1000 --max-connections-for-client 10
    sleep 2
    pgrep -f "badvpn-udpgw" > /dev/null \
        && log "OK [badvpn]: instancias reiniciadas" \
        || log "ERROR [badvpn]: no arrancó"
    _set_cd "badvpn"
}

do_restart_stunnel() {
    log "ACTION [stunnel]: systemctl restart stunnel4"
    systemctl restart stunnel4 >> "$LOG" 2>&1
    local EC=$?
    [ "$EC" -eq 0 ] && log "OK [stunnel]: reiniciado" || log "ERROR [stunnel]: fallo (exit $EC)"
    _set_cd "stunnel"
}

# ══════════════════════════════════════════════════════════════════════
# Acción escalonada fallback individual: SIGTERM → SIGKILL
# ══════════════════════════════════════════════════════════════════════
do_kill_fallback() {
    local TYPE="$1"
    local FB_NAME="$2"
    local FB_PID="$3"
    local CTR_DIR
    [ "$TYPE" = "cpu" ] && CTR_DIR="$FB_CPU_DIR" || CTR_DIR="$FB_RAM_DIR"
    local FB_CTR_F="${CTR_DIR}/pid_${FB_PID}"
    local FB_CTR
    FB_CTR=$(cat "$FB_CTR_F" 2>/dev/null || echo 0)

    if ! kill -0 "$FB_PID" 2>/dev/null; then
        log "FALLBACK-${TYPE^^}: PID $FB_PID ($FB_NAME) ya no existe"
        rm -f "$FB_CTR_F"; _set_cd "fallback_${TYPE}_${FB_PID}"
        return
    fi

    if [ "$FB_CTR" -eq "$( [ "$TYPE" = "cpu" ] && echo $FALLBACK_CPU_CYCLES || echo $FALLBACK_RAM_CYCLES )" ]; then
        log "ACTION [fallback-${TYPE}]: SIGTERM → $FB_NAME (PID $FB_PID)"
        kill -15 "$FB_PID" 2>/dev/null
        echo $(( FB_CTR + 1 )) > "$FB_CTR_F"
        log "INFO: esperando próximo ciclo para verificar si terminó"
        return
    fi

    if kill -0 "$FB_PID" 2>/dev/null; then
        log "ACTION [fallback-${TYPE}]: SIGKILL → $FB_NAME (PID $FB_PID) [ignoró SIGTERM]"
        kill -9 "$FB_PID" 2>/dev/null
        sleep 1
        kill -0 "$FB_PID" 2>/dev/null \
            && log "ERROR [fallback-${TYPE}]: PID $FB_PID no respondió a SIGKILL — posible hilo kernel" \
            || { log "OK [fallback-${TYPE}]: $FB_NAME terminado con SIGKILL"; rm -f "$FB_CTR_F"; }
    else
        log "OK [fallback-${TYPE}]: $FB_NAME (PID $FB_PID) terminó con SIGTERM"
        rm -f "$FB_CTR_F"
    fi
    _set_cd "fallback_${TYPE}_${FB_PID}"
}

# ══════════════════════════════════════════════════════════════════════
# Acción grupal (NUEVO v4.6): SIGTERM a todo el grupo → SIGKILL
#
# Primer ciclo de acción: SIGTERM a todos los PIDs del grupo.
# Siguiente ciclo: SIGKILL a los que no respondieron.
# Diseño deliberado: no mata de golpe con SIGKILL para dar chance
# a que terminen limpiamente (flush de buffers, cerrar archivos, etc.)
# ══════════════════════════════════════════════════════════════════════
do_kill_group() {
    local GRP_NAME="$1"
    local GRP_PIDS="$2"
    local GRP_CTR_F="${GRP_DIR}/${GRP_NAME}"
    local GRP_CTR
    GRP_CTR=$(cat "$GRP_CTR_F" 2>/dev/null || echo 0)

    # Verificar cuáles PIDs siguen vivos
    local ALIVE_PIDS=""
    for PID in $GRP_PIDS; do
        kill -0 "$PID" 2>/dev/null && ALIVE_PIDS="${ALIVE_PIDS}${PID} "
    done

    if [ -z "$ALIVE_PIDS" ]; then
        log "GROUP: todos los PIDs de '${GRP_NAME}' ya terminaron — limpiando"
        rm -f "$GRP_CTR_F"
        _set_cd "group_${GRP_NAME}"
        return
    fi

    local N_ALIVE
    N_ALIVE=$(echo "$ALIVE_PIDS" | wc -w)

    if [ "$GRP_CTR" -le "$GROUP_CPU_CYCLES" ]; then
        # Primera acción: SIGTERM a todos los vivos
        log "ACTION [group]: SIGTERM → grupo '${GRP_NAME}' (${N_ALIVE} PIDs vivos: ${ALIVE_PIDS})"
        for PID in $ALIVE_PIDS; do
            if kill -15 "$PID" 2>/dev/null; then
                log "  SIGTERM → ${GRP_NAME} [PID $PID]"
            else
                log "  SIGTERM falló → ${GRP_NAME} [PID $PID] (ya terminó?)"
            fi
        done
        echo $(( GRP_CTR + 1 )) > "$GRP_CTR_F"
        log "INFO [group]: esperando próximo ciclo para verificar sobrevivientes"
    else
        # Ciclos siguientes: SIGKILL a los que ignoraron SIGTERM
        log "ACTION [group]: SIGKILL → sobrevivientes de '${GRP_NAME}' (${N_ALIVE} PIDs)"
        local KILLED=0 GONE=0
        for PID in $ALIVE_PIDS; do
            if kill -0 "$PID" 2>/dev/null; then
                kill -9 "$PID" 2>/dev/null
                sleep 0
                if kill -0 "$PID" 2>/dev/null; then
                    log "  ERROR: ${GRP_NAME} [PID $PID] no respondió a SIGKILL — posible hilo kernel"
                else
                    log "  SIGKILL → ${GRP_NAME} [PID $PID] OK"
                    (( KILLED++ ))
                fi
            else
                log "  OK: ${GRP_NAME} [PID $PID] ya terminó (respondió SIGTERM)"
                (( GONE++ ))
            fi
        done
        log "OK [group]: '${GRP_NAME}' — ${KILLED} matados con SIGKILL, ${GONE} terminaron solos"
        rm -f "$GRP_CTR_F"
    fi
    _set_cd "group_${GRP_NAME}"
}

# ══════════════════════════════════════════════════════════════════════
# dispatch_action() — verifica cooldown y despacha la acción
# ══════════════════════════════════════════════════════════════════════
dispatch_action() {
    local REASON="$1"
    log "TRIGGER: $REASON → culprit=${CULPRIT}"

    case "$CULPRIT" in
        xray)
            _in_cd "xray" "$COOLDOWN_KNOWN" \
                && { log "CD [xray]: en cooldown ($(_cd_remaining xray $COOLDOWN_KNOWN)s restantes)"; return; }
            do_restart_xray ;;
        proxy)
            _in_cd "proxy" "$COOLDOWN_KNOWN" \
                && { log "CD [proxy]: en cooldown"; return; }
            do_restart_proxy ;;
        badvpn)
            _in_cd "badvpn" "$COOLDOWN_KNOWN" \
                && { log "CD [badvpn]: en cooldown"; return; }
            do_restart_badvpn ;;
        stunnel)
            _in_cd "stunnel" "$COOLDOWN_KNOWN" \
                && { log "CD [stunnel]: en cooldown"; return; }
            do_restart_stunnel ;;
        group:*)
            local GRP_NAME; GRP_NAME=$(echo "$CULPRIT" | cut -d: -f2)
            _in_cd "group_${GRP_NAME}" "$COOLDOWN_GROUP" \
                && { log "CD [group]: '${GRP_NAME}' en cooldown ($(_cd_remaining "group_${GRP_NAME}" $COOLDOWN_GROUP)s restantes)"; return; }
            do_kill_group "$GRP_NAME" "$CULPRIT_GROUP_PIDS" ;;
        fallback_cpu:*)
            local FB_NAME; FB_NAME=$(echo "$CULPRIT" | cut -d: -f2)
            local FB_PID;  FB_PID=$(echo  "$CULPRIT" | cut -d: -f3)
            local CD_KEY="fallback_cpu_${FB_PID}"
            _in_cd "$CD_KEY" "$COOLDOWN_FALLBACK" \
                && { log "CD [fallback-cpu]: $FB_NAME en cooldown"; return; }
            do_kill_fallback "cpu" "$FB_NAME" "$FB_PID" ;;
        fallback_ram:*)
            local FB_NAME; FB_NAME=$(echo "$CULPRIT" | cut -d: -f2)
            local FB_PID;  FB_PID=$(echo  "$CULPRIT" | cut -d: -f3)
            local CD_KEY="fallback_ram_${FB_PID}"
            _in_cd "$CD_KEY" "$COOLDOWN_FALLBACK" \
                && { log "CD [fallback-ram]: $FB_NAME en cooldown"; return; }
            do_kill_fallback "ram" "$FB_NAME" "$FB_PID" ;;
        unknown)
            log "WARN: culprit=unknown — sin proceso identificable — SIN ACCIÓN (falla segura)"
            return ;;
    esac
}

# ══════════════════════════════════════════════════════════════════════
# MAIN
# ══════════════════════════════════════════════════════════════════════
RAM_CTR=$(cat "$RAM_COUNTER_FILE" 2>/dev/null || echo 0)
CPU_CTR=$(cat "$CPU_COUNTER_FILE" 2>/dev/null || echo 0)

RAM_PCT=$(free | awk '/^Mem:/ {printf "%.0f", ($2-$7)/$2 * 100}')
if ! [[ "$RAM_PCT" =~ ^[0-9]+$ ]]; then
    log "ERROR: RAM inválida='$RAM_PCT' — abortando"; exit 1
fi

log "INFO: RAM=${RAM_PCT}% | ctrs RAM=${RAM_CTR} CPU=${CPU_CTR} | iniciando scan CPU real..."

identify_culprit

log "INFO: RAM=${RAM_PCT}% CPU_real=${SYS_CPU_PCT}% | culprit=${CULPRIT}"

# ── CPU crítica inmediata ─────────────────────────────────────────────
# Si el VPS ya está ahogado y el culpable fue identificado,
# forzar contador para que la acción sea inmediata sin esperar ciclo 2.
if [ "$SYS_CPU_PCT" -ge "$CPU_CRIT" ]; then
    if [[ "$CULPRIT" == fallback_cpu:* ]]; then
        FB_PID_CRIT=$(echo "$CULPRIT" | cut -d: -f3)
        FB_COMM_CRIT=$(echo "$CULPRIT" | cut -d: -f2)
        echo "$FALLBACK_CPU_CYCLES" > "${FB_CPU_DIR}/pid_${FB_PID_CRIT}"
        log "OVERRIDE: CPU crítica (${SYS_CPU_PCT}%>=${CPU_CRIT}%) + fallback ${FB_COMM_CRIT} [PID ${FB_PID_CRIT}] → acción INMEDIATA"
    elif [[ "$CULPRIT" == group:* ]]; then
        GRP_NAME_CRIT=$(echo "$CULPRIT" | cut -d: -f2)
        echo "$GROUP_CPU_CYCLES" > "${GRP_DIR}/${GRP_NAME_CRIT}"
        log "OVERRIDE: CPU crítica (${SYS_CPU_PCT}%>=${CPU_CRIT}%) + group '${GRP_NAME_CRIT}' → acción INMEDIATA (${CULPRIT_GROUP_PIDS})"
    fi
    dispatch_action "CPU crítica (${SYS_CPU_PCT}%>=${CPU_CRIT}%)"
fi

# ── RAM crítica inmediata ─────────────────────────────────────────────
if [ "$RAM_PCT" -ge "$RAM_CRIT" ]; then
    dispatch_action "RAM crítica (${RAM_PCT}%>=${RAM_CRIT}%)"
fi

# ── Contadores sostenidos CPU ─────────────────────────────────────────
if [ "$SYS_CPU_PCT" -ge "$CPU_WARN" ]; then
    CPU_CTR=$(( CPU_CTR + 1 ))
    echo "$CPU_CTR" > "$CPU_COUNTER_FILE"
    log "WARN: CPU alta (${SYS_CPU_PCT}%) — ciclo ${CPU_CTR}/${CYCLES_REQUIRED}"
    [ "$CPU_CTR" -ge "$CYCLES_REQUIRED" ] && \
        dispatch_action "CPU sostenida (${SYS_CPU_PCT}% x ${CPU_CTR} ciclos)"
else
    if [ "$CPU_CTR" -gt 0 ]; then
        CPU_CTR=$(( CPU_CTR - 1 ))
        echo "$CPU_CTR" > "$CPU_COUNTER_FILE"
        log "INFO: CPU bajó a ${SYS_CPU_PCT}% — contador decrementado a ${CPU_CTR}"
    fi
fi

# ── Contadores sostenidos RAM ─────────────────────────────────────────
if [ "$RAM_PCT" -ge "$RAM_WARN" ]; then
    RAM_CTR=$(( RAM_CTR + 1 ))
    echo "$RAM_CTR" > "$RAM_COUNTER_FILE"
    log "WARN: RAM alta (${RAM_PCT}%) — ciclo ${RAM_CTR}/${CYCLES_REQUIRED}"
    [ "$RAM_CTR" -ge "$CYCLES_REQUIRED" ] && \
        dispatch_action "RAM sostenida (${RAM_PCT}% x ${RAM_CTR} ciclos)"
else
    if [ "$RAM_CTR" -gt 0 ]; then
        RAM_CTR=$(( RAM_CTR - 1 ))
        echo "$RAM_CTR" > "$RAM_COUNTER_FILE"
        log "INFO: RAM bajó a ${RAM_PCT}% — contador decrementado a ${RAM_CTR}"
    fi
fi

# ── Fallback/grupo sostenido ──────────────────────────────────────────
if [[ "$CULPRIT" == fallback_cpu:* ]] || \
   [[ "$CULPRIT" == fallback_ram:* ]] || \
   [[ "$CULPRIT" == group:* ]]; then
    dispatch_action "Proceso/grupo externo sostenido detectado"
fi

log "INFO: ciclo completado → sin más acciones pendientes"
exit 0
EOF

chmod +x /root/xray_watchdog.sh

# ── Registrar cron — cada minuto ─────────────────────────────────────
CRON_TMP_WD=$(mktemp)
crontab -l 2>/dev/null > "$CRON_TMP_WD" || true
sed -i '/xray_watchdog\.sh/d' "$CRON_TMP_WD"
echo "* * * * * /root/xray_watchdog.sh" >> "$CRON_TMP_WD"
crontab "$CRON_TMP_WD"
